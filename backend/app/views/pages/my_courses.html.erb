<% content_for :title, "SpeakFlow | 내 강의" %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <section class="hero">
      <div class="eyebrow">수강 중인 강의</div>
      <h2>내 학습 현황을<br>한 번에 확인합니다.</h2>
      <p>수강 중인 강의 목록과 각 강의의 진행률을 확인할 수 있습니다.</p>
    </section>

    <% if @my_courses.any? %>
      <section class="stack-gap">
        <% @my_courses.each do |course| %>
          <% stats = course_progress_stats(@demo_user, course) %>
          <article class="card">
            <div class="section-head">
              <h3><%= course.title %></h3>
              <span class="badge"><%= course.category.name %></span>
            </div>
            <p><%= course.description %></p>
            <div class="meta">
              <div><span>강사</span><span><%= course.instructor_name %></span></div>
              <div><span>전체 강의</span><span><%= stats[:total] %></span></div>
              <div><span>완료한 강의</span><span><%= stats[:watched] %></span></div>
              <div><span>진행률</span><span><%= stats[:rate] %>%</span></div>
            </div>
            <div class="progress"><span style="width: <%= stats[:rate] %>%;"></span></div>
            <div class="btn-row">
              <%= link_to "강의 시청", lecture_player_path(course_id: course.id), class: "link-btn primary" %>
              <%= link_to "상세 보기", course_detail_path(course_id: course.id), class: "link-btn" %>
            </div>
          </article>
        <% end %>
      </section>
    <% else %>
      <article class="empty">수강 중인 강의가 없습니다.</article>
    <% end %>
  </section>
</main>
