<% content_for :title, "SpeakFlow | 내 강의" %>

<main class="page">
  <% if current_user %>
    <% enrolled_courses = current_user.learning_courses %>

    <section class="hero-shell">
      <div class="hero-shell__ambient" aria-hidden="true"></div>

      <div class="container hero-shell__grid">
        <div class="hero-shell__copy">
          <p class="eyebrow">My courses</p>
          <h1 class="hero-shell__title">지금 학습 중인 강의</h1>
          <p class="hero-shell__body">내가 수강 중인 강의를 확인하고 관리할 수 있습니다.</p>

          <div class="button-row">
            <%= link_to "새 강의 탐색", courses_path, class: "button button--secondary" %>
            <%= link_to "진도 보기", progress_path, class: "button button--primary" %>
          </div>
        </div>

        <aside class="hero-focus">
          <div class="hero-focus__glow" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

          <div class="hero-focus__content">
            <span class="pill pill--accent">Active learning</span>
            <strong><%= enrolled_courses.count %>개의 과정이 현재 진행 중입니다.</strong>
            <p>과정별 진도와 복습 루틴을 하나의 시스템 안에서 이어 갈 수 있습니다.</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="surface">
      <div class="container surface__inner">
        <section class="page-section">
          <% if enrolled_courses.any? %>
            <div class="course-grid">
              <% enrolled_courses.each do |course| %>
                <% stats = course_progress_stats(current_user, course) %>
                <article class="course-card">
                  <div class="course-card__top">
                    <div>
                      <span class="pill pill--accent"><%= course.category.name %></span>
                      <h3 style="margin-top: 14px;"><%= course.title %></h3>
                    </div>

                    <span class="orb-ripple" aria-hidden="true">
                      <span class="orb-ripple__ring orb-ripple__ring--a"></span>
                      <span class="orb-ripple__ring orb-ripple__ring--b"></span>
                      <span class="orb-ripple__ring orb-ripple__ring--c"></span>
                      <span class="orb-ripple__core"></span>
                    </span>
                  </div>

                  <p><%= truncate(course.description, length: 140) %></p>

                  <div>
                    <div class="split-between" style="margin-bottom: 8px;">
                      <span class="meta-copy">진도</span>
                      <strong><%= stats[:rate] %>%</strong>
                    </div>
                    <div class="progress-track"><span style="width: <%= stats[:rate] %>%;"></span></div>
                  </div>

                  <div class="meta-list">
                    <div class="meta-item"><span>완료 강의</span><strong><%= stats[:watched] %> / <%= stats[:total] %></strong></div>
                    <div class="meta-item"><span>강사</span><strong><%= course.instructor_name %></strong></div>
                  </div>

                  <div class="button-row">
                    <%= link_to "과정 열기", course_detail_path(course), class: "button button--primary button--small" %>
                  </div>
                </article>
              <% end %>
            </div>
          <% else %>
            <article class="surface-card">
              <h3>아직 등록된 강의가 없습니다.</h3>
              <p style="margin-top: 14px;">멤버십을 시작하거나 강의를 등록하면 이 영역이 당신의 중심 학습 보드가 됩니다.</p>
              <div class="button-row" style="margin-top: 18px;">
                <%= link_to "멤버십 보기", membership_path, class: "button button--primary button--small" %>
              </div>
            </article>
          <% end %>
        </section>
      </div>
    </section>
  <% else %>
    <section class="hero-shell">
      <div class="container">
        <article class="surface-card">
          <h3>내 강의는 로그인 후 사용할 수 있어요.</h3>
          <p style="margin-top: 14px;">학습 흐름을 저장하고 이어 보려면 먼저 계정이 필요합니다.</p>
          <div class="button-row" style="margin-top: 18px;">
            <%= link_to "로그인", login_path, class: "button button--primary button--small" %>
          </div>
        </article>
      </div>
    </section>
  <% end %>
</main>
