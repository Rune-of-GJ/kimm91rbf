<% content_for :title, "내 강의 | SpeakFlow" %>

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>내 강의 | SpeakFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 text-white">
  <!-- 헤더 -->
  <header class="sticky top-0 z-50 border-b border-blue-500/20 bg-slate-900/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <%= link_to "🎤 SpeakFlow", root_path, class: "text-2xl font-black text-blue-400 no-underline" %>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-sm text-blue-300"><%= current_user.name %></span>
        <%= button_to "로그아웃", api_v1_auth_logout_path, method: :post, class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded font-medium transition" %>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-black text-white mb-8">내 강의</h1>

    <% if current_user.enrolled_courses.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% current_user.enrolled_courses.each do |course| %>
          <div class="bg-slate-800 border border-green-500/30 hover:border-green-500 rounded-lg overflow-hidden transition group">
            <div class="h-40 bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center text-6xl">✅</div>
            <div class="p-6">
              <h3 class="font-bold text-lg text-white mb-1 group-hover:text-green-300 transition"><%= course.title %></h3>
              <p class="text-sm text-slate-400 mb-2">👨‍🏫 <%= course.instructor_name %></p>
              <p class="text-slate-300 text-sm mb-4"><%= course.description %></p>
              
              <!-- 진도 바 -->
              <% total = course.lectures.count %>
              <% watched = current_user.progresses.where(lecture_id: course.lecture_ids, watched: true).count %>
              <% rate = total.zero? ? 0 : ((watched.to_f / total) * 100).round %>
              <div class="mb-3">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs text-slate-400">진도:</span>
                  <span class="text-xs font-semibold text-green-400"><%= rate %>%</span>
                </div>
                <div class="w-full bg-slate-700 rounded-full h-2 overflow-hidden">
                  <div class="bg-gradient-to-r from-green-500 to-emerald-500 h-full" style="width: <%= rate %>%"></div>
                </div>
              </div>

              <%= link_to "강의 시작", course_detail_path(course_id: course.id), class: "w-full inline-block px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded font-semibold text-center transition no-underline" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 bg-slate-800/50 rounded-lg border border-slate-700">
        <p class="text-2xl text-slate-400 mb-4">아직 수강하는 강의가 없습니다.</p>
        <%= link_to "강의 탐색하기", courses_path, class: "inline-block px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold transition no-underline" %>
      </div>
    <% end %>
  </main>
</body>
</html>
</main>
