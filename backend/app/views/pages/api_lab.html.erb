<% content_for :title, "SpeakFlow | API Lab" %>

<main class="page">
  <section class="hero-shell">
    <div class="hero-shell__ambient" aria-hidden="true"></div>

    <div class="container hero-shell__grid">
      <div class="hero-shell__copy">
        <p class="eyebrow">API 실험실</p>
        <h1 class="hero-shell__title">인증, 강의 조회, 진도 저장 흐름을 한 자리에서 테스트합니다.</h1>
        <p class="hero-shell__body">
          현재 P1 범위의 API 흐름을 확인할 수 있도록 인증, 카테고리, 강의, 진도 중심으로 구성했습니다.
        </p>
      </div>

      <aside class="hero-focus">
        <div class="hero-focus__glow" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

        <div class="hero-focus__content">
          <span class="pill pill--accent">Sample ids</span>
          <div class="meta-list">
            <div class="meta-item"><span>카테고리</span><strong><%= @lab_category&.id || "없음" %></strong></div>
            <div class="meta-item"><span>강의</span><strong><%= @lab_course&.id || "없음" %></strong></div>
            <div class="meta-item"><span>레슨</span><strong><%= @lab_lecture&.id || "없음" %></strong></div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface">
    <div class="container surface__inner" data-controller="api-lab">
      <section class="page-section">
        <div class="lab-grid">
          <article class="lab-panel">
            <h3>인증</h3>
            <div class="field">
              <label for="lab-name">이름</label>
              <input id="lab-name" type="text" value="테스트 사용자" data-api-lab-target="name">
            </div>
            <div class="field">
              <label for="lab-email">이메일</label>
              <input id="lab-email" type="email" value="student@speakflow.kr" data-api-lab-target="email">
            </div>
            <div class="field">
              <label for="lab-password">비밀번호</label>
              <input id="lab-password" type="password" value="password123" data-api-lab-target="password">
            </div>
            <div class="button-row">
              <button type="button" class="button button--primary button--small" data-action="api-lab#signup">회원가입</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#login">로그인</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#refresh">세션 확인</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#logout">로그아웃</button>
            </div>
          </article>

          <article class="lab-panel">
            <h3>카테고리 / 강의 조회</h3>
            <div class="field">
              <label for="lab-category-id">카테고리 ID</label>
              <input id="lab-category-id" type="number" value="<%= @lab_category&.id || 1 %>" data-api-lab-target="categoryId">
            </div>
            <div class="field">
              <label for="lab-course-id">강의 ID</label>
              <input id="lab-course-id" type="number" value="<%= @lab_course&.id || 1 %>" data-api-lab-target="courseId">
            </div>
            <div class="button-row">
              <button type="button" class="button button--primary button--small" data-action="api-lab#categoriesIndex">카테고리 목록</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#categoriesShow">카테고리 상세</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#coursesIndex">강의 목록</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#coursesShow">강의 상세</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#lecturesIndex">레슨 목록</button>
            </div>
          </article>

          <article class="lab-panel">
            <h3>레슨 / 진도</h3>
            <div class="field">
              <label for="lab-lecture-id">레슨 ID</label>
              <input id="lab-lecture-id" type="number" value="<%= @lab_lecture&.id || 1 %>" data-api-lab-target="lectureId">
            </div>
            <div class="field">
              <label for="lab-watched">시청 완료 여부</label>
              <select id="lab-watched" data-api-lab-target="watched">
                <option value="true" selected>true</option>
                <option value="false">false</option>
              </select>
            </div>
            <div class="button-row">
              <button type="button" class="button button--primary button--small" data-action="api-lab#lectureShow">레슨 상세</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#progressSave">진도 저장</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#myCourses">내 강의</button>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#myProgress">내 진도</button>
            </div>
          </article>

          <article class="response-panel">
            <div class="split-between">
              <h3>응답 JSON</h3>
              <button type="button" class="button button--secondary button--small" data-action="api-lab#clear">지우기</button>
            </div>
            <pre class="response-box" data-api-lab-target="response">버튼을 누르면 응답이 여기에 표시됩니다.</pre>
          </article>
        </div>
      </section>
    </div>
  </section>
</main>
