<% content_for :title, "SpeakFlow | 회원가입" %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <section class="hero">
      <div class="eyebrow">회원가입</div>
      <h2>처음이라면<br>여기서 시작하세요.</h2>
      <p>간단한 가입 후 바로 강의를 둘러보고 학습을 시작할 수 있습니다.</p>
    </section>

    <article class="form-card">
      <div class="field"><label>이름</label><input type="text" placeholder="이름 입력"></div>
      <div class="field"><label>이메일</label><input type="email" placeholder="student@speakflow.kr"></div>
      <div class="field"><label>비밀번호</label><input type="password" placeholder="최소 8자 이상"></div>
      <div class="btn-row">
        <button class="btn primary" type="button" disabled>회원가입</button>
      </div>
    </article>
  </section>
</main>
