<% content_for :title, "SpeakFlow | 강의 목록" %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <section class="hero">
      <div class="hero-grid">
        <div>
          <div class="eyebrow">강의 탐색</div>
          <h2><%= @selected_category ? "#{@selected_category.name} 강의" : "지금 들을 수 있는 강의" %></h2>
          <p><%= @selected_category ? "선택한 카테고리에 등록된 강의만 모아 보여줍니다." : "전체 강의를 한 번에 둘러보고 원하는 과정을 선택할 수 있습니다." %></p>
        </div>
        <aside class="preview-panel">
          <div class="preview-screen">
            <div class="section-title"><%= @courses.first&.title || "강의 준비 중" %></div>
            <p><%= @courses.first&.description || "현재 표시할 강의가 없습니다." %></p>
            <div class="floating-card">
              <strong><%= @courses.size %>개 강의</strong>
              <div class="small-note"><%= @selected_category ? @selected_category.name : "전체 카테고리" %></div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <% if @courses.any? %>
      <section class="stack-gap">
        <% @courses.each do |course| %>
          <article class="card">
            <div class="section-head">
              <h3><%= course.title %></h3>
              <span class="badge"><%= course.category.name %></span>
            </div>
            <p><%= course.description %></p>
            <div class="meta">
              <div><span>강사</span><span><%= course.instructor_name %></span></div>
              <div><span>강의 수</span><span><%= course.lectures.size %></span></div>
              <div><span>수강 상태</span><span><%= @demo_user&.enrollments&.exists?(course_id: course.id) ? "수강 중" : "미수강" %></span></div>
            </div>
            <div class="btn-row">
              <%= link_to "상세 보기", course_detail_path(course_id: course.id), class: "link-btn primary" %>
              <button class="btn" type="button" disabled>수강 신청</button>
            </div>
          </article>
        <% end %>
      </section>
    <% else %>
      <article class="empty">선택한 카테고리에 등록된 강의가 없습니다.</article>
    <% end %>
  </section>
</main>
