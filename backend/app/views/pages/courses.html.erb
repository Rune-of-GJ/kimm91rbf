<% content_for :title, "SpeakFlow | Courses" %>

<% selected_label = @selected_category&.name || "전체 강의" %>
<% enrolled_ids = current_user ? current_user.enrolled_courses.ids : [] %>

<main class="page">
  <section class="hero-shell">
    <div class="hero-shell__ambient" aria-hidden="true"></div>

    <div class="container hero-shell__grid">
      <div class="hero-shell__copy">
        <p class="eyebrow">Course library</p>
        <h1 class="hero-shell__title"><%= selected_label %>에서<br>나에게 맞는 강의는?</h1>
        <p class="hero-shell__body">
          카테고리별로 강의를 탐색해 보세요.
        </p>

        <div class="button-row">
          <%= link_to "카테고리 보기", categories_path, class: "button button--secondary" %>
          <% if current_user %>
            <%= link_to "내 강의 보기", my_courses_path, class: "button button--primary" %>
          <% else %>
            <%= link_to "로그인", login_path, class: "button button--primary" %>
          <% end %>
        </div>
      </div>

      <aside class="hero-focus">
        <div class="hero-focus__glow" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

        <div class="hero-focus__content">
          <span class="pill pill--accent">Browse cue</span>
          <strong><%= @courses.count %>개의 강의가 현재 목록에 있습니다.</strong>
          <p>카테고리와 커리큘럼을 먼저 비교하고 내 학습 흐름에 맞는 강의를 골라볼 수 있습니다.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface">
    <div class="container surface__inner">
      <section class="page-section">
        <div class="chip-row" style="margin-bottom: 22px;">
          <%= link_to "전체", courses_path, class: "category-filter #{params[:category].blank? ? 'is-active' : ''}" %>
          <% @categories.each do |category| %>
            <%= link_to category.name, courses_path(category: category.id), class: "category-filter #{params[:category].to_s == category.id.to_s ? 'is-active' : ''}" %>
          <% end %>
        </div>

        <% if @courses.any? %>
          <div class="course-grid">
            <% @courses.each do |course| %>
              <article class="course-card">
                <div class="course-card__top">
                  <div>
                    <span class="pill"><%= course.category.name %></span>
                    <h3 style="margin-top: 14px;"><%= course.title %></h3>
                  </div>

                  <span class="micro-ripple" aria-hidden="true">
                    <span class="micro-ripple__ring micro-ripple__ring--a"></span>
                    <span class="micro-ripple__ring micro-ripple__ring--b"></span>
                    <span class="micro-ripple__ring micro-ripple__ring--c"></span>
                    <span class="micro-ripple__core"></span>
                  </span>
                </div>

                <p><%= truncate(course.description, length: 140) %></p>

                <div class="meta-list">
                  <div class="meta-item"><span>강사</span><strong><%= course.instructor_name %></strong></div>
                  <div class="meta-item"><span>강의 수</span><strong><%= course.lectures.count %>개</strong></div>
                  <div class="meta-item"><span>개강일</span><strong><%= display_date(course.start_date) %></strong></div>
                </div>

                <div class="button-row">
                  <%= link_to "상세 보기", course_detail_path(course), class: "button button--secondary button--small" %>
                  <% if enrolled_ids.include?(course.id) %>
                    <span class="pill pill--accent">수강 중</span>
                  <% elsif current_user %>
                    <%= link_to "수강하기", course_detail_path(course), class: "button button--primary button--small" %>
                  <% else %>
                    <%= link_to "로그인", login_path, class: "button button--primary button--small" %>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        <% else %>
          <article class="surface-card">
            <h3>해당 카테고리에는 아직 공개된 강의가 없습니다.</h3>
            <p style="margin-top: 14px;">다른 카테고리에서 새 강의를 찾아보세요.</p>
          </article>
        <% end %>
      </section>
    </div>
  </section>
</main>
