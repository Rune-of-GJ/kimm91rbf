<% content_for :title, "SpeakFlow | 강의 상세" %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <% if @featured_course %>
      <% first_lecture = @curriculum.first %>
      <section class="hero">
        <div class="hero-grid">
          <div>
            <div class="eyebrow"><%= @featured_course.category.name %></div>
            <h2><%= @featured_course.title %></h2>
            <p><%= @featured_course.description %></p>
            <div class="badge-row">
              <span class="badge"><%= @featured_course.instructor_name %> 강사</span>
              <span class="badge"><%= @demo_user&.enrollments&.exists?(course_id: @featured_course.id) ? "수강 중" : "수강 전" %></span>
              <span class="badge">총 <%= @curriculum.size %>강</span>
            </div>
            <div class="hero-actions">
              <button class="btn primary" type="button" disabled>수강 신청</button>
              <% if first_lecture %>
                <%= link_to "강의 시청", lecture_player_path(course_id: @featured_course.id, lecture_id: first_lecture.id), class: "link-btn" %>
              <% end %>
            </div>
          </div>
          <aside class="preview-panel">
            <div class="preview-screen">
              <% if first_lecture %>
                <%= link_to "▶", lecture_player_path(course_id: @featured_course.id, lecture_id: first_lecture.id), class: "preview-play play-link", aria: { label: "강의 재생" } %>
              <% else %>
                <div class="preview-play">▶</div>
              <% end %>
              <div>
                <div class="section-title">강의 미리보기</div>
                <p>첫 강의부터 순서대로 학습할 수 있도록 커리큘럼을 구성했습니다.</p>
              </div>
              <div class="floating-card">
                <strong><%= first_lecture&.title || "강의 준비 중" %></strong>
                <div class="small-note">첫 번째 학습 영상</div>
              </div>
            </div>
          </aside>
        </div>
      </section>

      <section class="grid-2">
        <article class="card">
          <h3>강의 정보</h3>
          <div class="meta">
            <div><span>수강 시작일</span><span><%= display_value(@featured_course.start_date) %></span></div>
            <div><span>수강 종료일</span><span><%= display_value(@featured_course.end_date) %></span></div>
            <div><span>신청 마감일</span><span><%= display_value(@featured_course.enrollment_deadline) %></span></div>
            <div><span>최대 수강일</span><span><%= display_value(@featured_course.max_access_days) %></span></div>
            <div><span>수강 가능 여부</span><span><%= boolean_label(@featured_course.available_on?) %></span></div>
            <div><span>신청 가능 여부</span><span><%= boolean_label(@featured_course.enrollment_open?) %></span></div>
          </div>
        </article>

        <article class="card">
          <h3>커리큘럼</h3>
          <table class="table">
            <tr><th>순서</th><th>강의명</th><th>재생 시간</th></tr>
            <% @curriculum.each do |lecture| %>
              <tr><td><%= lecture.order_no %></td><td><%= lecture.title %></td><td><%= duration_label(lecture.duration) %></td></tr>
            <% end %>
          </table>
        </article>
      </section>
    <% else %>
      <article class="empty">표시할 강의가 없습니다.</article>
    <% end %>
  </section>
</main>
