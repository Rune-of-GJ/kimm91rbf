<% content_for :title, "#{@course.title} | SpeakFlow" %>

<% enrolled = current_user ? current_user.can_access_course?(@course) : false %>
<% first_lecture = @lectures.first %>
<% learning_anchor = "learning-checkpoint" %>

<main class="page">
  <section class="hero-shell">
    <div class="hero-shell__ambient" aria-hidden="true"></div>

    <div class="container hero-shell__grid">
      <div class="hero-shell__copy">
        <p class="eyebrow">Course detail</p>
        <h1 class="hero-shell__title"><%= @course.title %></h1>
        <p class="hero-shell__body"><%= @course.description %></p>

        <div class="button-row">
          <% if current_user && enrolled && first_lecture.present? %>
            <%= link_to "바로 학습하기", lecture_player_path(first_lecture), class: "button button--primary" %>
          <% elsif current_user && enrolled %>
            <%= link_to "내 강의로 이동", my_courses_path, class: "button button--primary" %>
          <% elsif current_user %>
            <%= link_to "멤버십으로 학습", membership_checkout_path(plan: "pro"), class: "button button--primary" %>
          <% else %>
            <%= link_to "로그인", login_path(return_to: request.fullpath), class: "button button--primary" %>
          <% end %>

          <%= link_to "전체 강의 보기", courses_path, class: "button button--secondary" %>
        </div>
      </div>

      <aside class="hero-focus">
        <div class="hero-focus__glow" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

        <div class="hero-focus__content">
          <span class="pill pill--accent"><%= @course.category.name %></span>
          <strong><%= @lectures.count %>개의 강의가 하나의 학습 흐름으로 이어집니다.</strong>
          <p>강의 정보, 일정, 커리큘럼을 먼저 확인한 뒤 학습을 이어갈 수 있도록 구성했습니다.</p>

          <div class="meta-list">
            <div class="meta-item"><span>강사</span><strong><%= @course.instructor_name %></strong></div>
            <div class="meta-item"><span>개강일</span><strong><%= display_date(@course.start_date) %></strong></div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface">
    <div class="container surface__inner">
      <section class="page-section">
        <div class="detail-grid">
          <article class="summary-panel">
            <span class="pill">Course summary</span>
            <h3 style="margin-top: 14px;"><%= @course.title %></h3>
            <p style="margin-top: 14px;">
              강의의 메시지, 전달 방식, 커리큘럼 순서를 차분하게 훑어볼 수 있도록 정리했습니다.
            </p>
            <div class="meta-list" style="margin-top: 20px;">
              <div class="meta-item"><span>카테고리</span><strong><%= @course.category.name %></strong></div>
              <div class="meta-item"><span>강의 수</span><strong><%= @lectures.count %>개</strong></div>
            </div>
          </article>

          <article class="surface-card" id="<%= learning_anchor %>">
            <h3>학습 체크 포인트</h3>
            <p style="margin-top: 14px;">일정과 수강 상태를 확인하고 필요한 경우 내 강의 화면으로 이동할 수 있습니다.</p>
            <div class="meta-list" style="margin-top: 18px;">
              <div class="meta-item"><span>수강 상태</span><strong><%= enrolled ? "학습 가능" : "미구독" %></strong></div>
              <div class="meta-item"><span>수강 마감</span><strong><%= display_date(@course.enrollment_deadline) %></strong></div>
              <div class="meta-item"><span>강사</span><strong><%= @course.instructor_name %></strong></div>
            </div>
            <% if current_user && !enrolled %>
              <div class="status-banner" style="margin-top: 18px;">
                SpeakFlow 멤버십을 시작하면 이 강의를 바로 학습할 수 있습니다.
              </div>
            <% end %>
          </article>
        </div>
      </section>

      <section class="page-section">
        <div class="section-heading">
          <h2 class="section-title">강의 리스트</h2>
          <p class="section-copy">현재 강의에 포함된 커리큘럼을 순서대로 확인할 수 있습니다.</p>
        </div>

        <div class="lecture-list">
          <% @lectures.each do |lecture| %>
            <% complete = watched?(current_user, lecture) %>
            <article class="lecture-card <%= 'is-complete' if complete %>">
              <div class="lecture-card__top">
                <div style="display: flex; gap: 16px; align-items: flex-start;">
                  <span class="lecture-badge <%= 'is-complete' if complete %>"><%= lecture.order_no %></span>
                  <div>
                    <h3><%= lecture.title %></h3>
                    <p style="margin-top: 10px;">예상 시간 <%= duration_label(lecture.duration) %></p>
                  </div>
                </div>

                <div class="button-row">
                  <% if complete %>
                    <span class="pill pill--accent">시청 완료</span>
                  <% end %>

                  <% if enrolled %>
                    <%= link_to "시청하기", lecture_player_path(lecture), class: "button button--secondary button--small" %>
                  <% elsif current_user %>
                    <%= link_to "멤버십 가입", membership_checkout_path(plan: "pro"), class: "button button--secondary button--small" %>
                  <% else %>
                    <span class="pill">로그인 후 학습</span>
                  <% end %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    </div>
  </section>
</main>
