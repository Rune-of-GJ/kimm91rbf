<% content_for :title, "#{@course.title} | SpeakFlow" %>

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @course.title %> - SpeakFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    [hidden] { display: none !important; }
    body { @apply bg-gradient-to-br from-slate-800 via-slate-700 to-slate-800; }
  </style>
</head>
<body class="text-white">
  <!-- 헤더 -->
  <header class="sticky top-0 z-50 border-b border-blue-500/20 bg-slate-900/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <%= link_to root_path do %>
          <div class="flex flex-col items-center">
            <img src="/speak.png" alt="SpeakFlow" class="h-16 w-auto">
            <span class="text-slate-400 text-sm mt-1">발표 능력 향상 플랫폼</span>
          </div>
        <% end %>
      </div>
      <div class="flex items-center gap-4">
        <% if current_user %>
          <button onclick="toggleSidebar()" class="text-white hover:text-blue-300 transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        <% else %>
          <%= link_to "로그인/가입", login_path, class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-medium transition" %>
        <% end %>
      </div>
    </div>
  </header>

  <main class="bg-slate-800 min-h-screen">
    <div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Flash messages -->
    <% if notice %>
      <div class="mb-6 p-4 bg-green-600 text-white rounded-lg">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="mb-6 p-4 bg-red-600 text-white rounded-lg">
        <%= alert %>
      </div>
    <% end %>

    <!-- 강의 정보 -->
    <div class="mb-8">
      <div class="flex items-start gap-6">
        <div class="w-48 h-32 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-lg flex items-center justify-center text-4xl">🎯</div>
        <div class="flex-1">
          <h1 class="text-3xl font-bold text-white mb-2"><%= @course.title %></h1>
          <p class="text-slate-300 mb-4"><%= @course.description %></p>
          <div class="flex items-center gap-4 text-sm text-slate-400">
            <span>👨‍🏫 <%= @course.instructor_name %></span>
            <span>📚 <%= @lectures.count %>강</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 강의 목록 -->
    <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
      <div class="p-6 border-b border-slate-700">
        <h2 class="text-xl font-semibold text-white">강의 목록</h2>
      </div>
      <div class="divide-y divide-slate-700">
        <% @lectures.each do |lecture| %>
          <div class="p-6 hover:bg-slate-700/50 transition">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center text-white font-bold">
                  <%= lecture.order_no %>
                </div>
                <div>
                  <h3 class="font-semibold text-white"><%= lecture.title %></h3>
                  <p class="text-sm text-slate-400">재생시간: <%= lecture.duration %>분</p>
                </div>
              </div>
              <%= link_to "시청하기", lecture_player_path(lecture), class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-medium transition" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    </div>
  </main>

  <!-- 사용자 사이드바 -->
  <% if current_user %>
    <div id="user-sidebar" class="fixed inset-y-0 right-0 z-50 w-64 bg-slate-800 border-l border-slate-700 transform translate-x-full transition-transform duration-300 ease-in-out">
      <div class="p-6">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-white">메뉴</h3>
          <button onclick="toggleSidebar()" class="text-slate-400 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <div class="space-y-4">
          <div class="text-center">
            <p class="text-blue-300 font-semibold"><%= current_user.name %> 님</p>
            <p class="text-slate-400 text-sm"><%= current_user.email %></p>
          </div>
          <div class="border-t border-slate-700 pt-4">
            <button onclick="logout()" class="w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded font-medium transition">
              로그아웃
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <script>
    function toggleSidebar() {
      const sidebar = document.getElementById('user-sidebar');
      sidebar.classList.toggle('translate-x-full');
    }

    async function logout() {
      try {
        await fetch('/api/v1/auth/logout', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
          }
        });
        window.location.href = '/';
      } catch (error) {
        console.error('Logout error:', error);
        window.location.href = '/';
      }
    }
  </script>
</body>
</html>
