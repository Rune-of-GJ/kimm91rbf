<% content_for :title, "SpeakFlow | 로그인" %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <section class="hero">
      <div class="eyebrow">로그인</div>
      <h2>이어 하던 학습을<br>바로 계속하세요.</h2>
      <p>이메일과 비밀번호로 로그인한 뒤 수강 중인 강의와 진도를 바로 확인할 수 있습니다.</p>
    </section>

    <article class="form-card">
      <div class="field"><label>이메일</label><input type="email" placeholder="student@speakflow.kr"></div>
      <div class="field"><label>비밀번호</label><input type="password" placeholder="비밀번호 입력"></div>
      <div class="btn-row">
        <button class="btn primary" type="button" disabled>로그인</button>
      </div>
    </article>
  </section>
</main>
