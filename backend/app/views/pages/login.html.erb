<% content_for :title, "SpeakFlow | 로그인" %>

<main class="page">
  <section class="hero-shell">
    <div class="container auth-layout"
      data-controller="auth"
      data-auth-initial-mode-value="<%= params[:signup] == 'true' ? 'signup' : 'login' %>"
      data-auth-login-url-value="<%= api_v1_auth_login_path %>"
      data-auth-signup-url-value="<%= api_v1_auth_signup_path %>"
      data-auth-return-to-value="<%= params[:return_to].to_s.match?(%r{\A/[^/]}) ? params[:return_to] : '/' %>">

      <aside class="auth-visual">
        <div class="auth-visual__glow" aria-hidden="true"></div>
        <div class="auth-visual__rings" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div style="position: relative; z-index: 1; display: grid; gap: 26px; align-content: end; min-height: 100%;">
          <div class="auth-visual__logo">
            <%= image_tag "ripple-logo.png", alt: "SpeakFlow ripple logo" %>
          </div>

          <div>
            <p class="eyebrow">SpeakFlow 시작하기</p>
            <h1 class="auth-title" style="margin-top: 16px;">SpeakFlow와<br>함께하세요.</h1>
            <p class="auth-copy" style="margin-top: 16px;">
              계정을 만들어 SpeakFlow의 모든 강의와 기능을 이용해 보세요.<br>이미 계정이 있다면 로그인 후 바로 학습을 시작할 수 있습니다.
            </p>
          </div>
        </div>
      </aside>

      <section class="auth-panel">
        <p class="eyebrow">계정 접근</p>

        <div data-auth-target="loginHeader">
          <h2 class="auth-title">SpeakFlow에<br>로그인하세요.</h2>
          <p class="auth-copy">돌아오셨군요! 로그인하세요.</p>
        </div>

        <div data-auth-target="signupHeader" hidden>
          <h2 class="auth-title">SpeakFlow에<br>회원가입하세요.</h2>
          <p class="auth-copy">처음이라면 회원가입하세요.</p>
        </div>

        <div data-auth-target="status" class="status-banner" hidden></div>

        <div data-auth-target="loginPanel">
          <form action="<%= api_v1_auth_login_path %>" method="post" data-mode="login" data-action="submit->auth#submit">
            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
            <div class="field">
              <label for="login-email">이메일</label>
              <input id="login-email" name="email" type="email" required autocomplete="email">
            </div>

            <div class="field" style="margin-top: 14px;">
              <label for="login-password">비밀번호</label>
              <input id="login-password" name="password" type="password" required autocomplete="current-password">
            </div>

            <div class="button-row" style="margin-top: 18px;">
              <button type="submit" class="button button--primary" data-auth-target="submit">로그인</button>
              <button type="button" class="button button--secondary" data-action="auth#showSignup">회원가입</button>
            </div>
          </form>
        </div>

        <div data-auth-target="signupPanel" hidden>
          <form action="<%= api_v1_auth_signup_path %>" method="post" data-mode="signup" data-action="submit->auth#submit">
            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
            <div class="field">
              <label for="signup-name">이름</label>
              <input id="signup-name" name="name" type="text" required autocomplete="name">
            </div>

            <div class="field" style="margin-top: 14px;">
              <label for="signup-email">이메일</label>
              <input id="signup-email" name="email" type="email" required autocomplete="email">
            </div>

            <div class="field" style="margin-top: 14px;">
              <label for="signup-password">비밀번호</label>
              <input id="signup-password" name="password" type="password" required minlength="8" autocomplete="new-password">
            </div>

            <div class="button-row" style="margin-top: 18px;">
              <button type="submit" class="button button--primary" data-auth-target="submit">회원가입</button>
              <button type="button" class="button button--secondary" data-action="auth#showLogin">로그인으로 돌아가기</button>
            </div>
          </form>
        </div>
      </section>
    </div>
  </section>
</main>
