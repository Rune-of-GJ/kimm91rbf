<% content_for :title, "SpeakFlow | 홈" %>

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SpeakFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    [hidden] { display: none !important; }
    body { @apply bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900; }
  </style>
</head>
<body class="text-white">
  <!-- 헤더 -->
  <header class="sticky top-0 z-50 border-b border-blue-500/20 bg-slate-900/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="text-2xl font-black text-blue-400">🎤 SpeakFlow</div>
        <span class="text-slate-400 text-sm">발표 능력 향상 플랫폼</span>
      </div>
      <div class="flex items-center gap-4">
        <% if current_user %>
          <div class="text-right text-sm hidden sm:block">
            <p class="text-blue-300 font-semibold"><%= current_user.name %></p>
            <p class="text-slate-400 text-xs"><%= current_user.email %></p>
          </div>
          <%= button_to "로그아웃", api_v1_auth_logout_path, method: :post, class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded font-medium transition" %>
        <% else %>
          <%= link_to "로그인/가입", "#auth-panel", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-medium transition" %>
        <% end %>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-12">
    <!-- 히어로 -->
    <% unless current_user %>
      <section class="mb-12 text-center py-12">
        <h1 class="text-5xl font-black text-white mb-4">뛰어난 발표자로 거듭나세요</h1>
        <p class="text-xl text-slate-300 mb-6">전문 강사와 함께하는 스피치, 발표, 소통 능력 향상</p>
        <%= link_to "무료로 시작하기", "#auth-panel", class: "inline-block px-8 py-3 bg-gradient-to-r from-blue-500 to-cyan-500 hover:from-blue-600 hover:to-cyan-600 text-white rounded-lg font-bold text-lg transition shadow-lg" %>
      </section>
    <% end %>

    <!-- 탭 (로그인 시) -->
    <% if current_user %>
      <div class="flex gap-4 mb-8 border-b border-slate-700">
        <button onclick="showTab('browse')" class="px-4 py-3 font-semibold border-b-2 text-blue-400 border-blue-400">강의 탐색</button>
        <button onclick="showTab('my-courses')" class="px-4 py-3 font-semibold border-b-2 text-slate-400 border-transparent hover:text-slate-300">내 강의</button>
        <button onclick="showTab('progress')" class="px-4 py-3 font-semibold border-b-2 text-slate-400 border-transparent hover:text-slate-300">학습 진도</button>
      </div>

      <!-- 강의 탐색 -->
      <section id="browse">
      <div class="flex gap-4 mb-6 overflow-x-auto pb-2">
        <%= link_to "전체", root_path, class: "px-4 py-2 rounded-full font-semibold whitespace-nowrap bg-blue-600 text-white" %>
        <% @categories.each do |cat| %>
          <%= link_to cat.name, "/?category=#{cat.id}", class: "px-4 py-2 rounded-full font-semibold whitespace-nowrap bg-slate-700 text-slate-300 hover:bg-slate-600 transition" %>
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @courses.each do |course| %>
          <div class="bg-slate-800 border border-slate-700 hover:border-blue-500 rounded-lg overflow-hidden transition group">
            <div class="h-40 bg-gradient-to-br from-blue-500 to-cyan-600 flex items-center justify-center text-6xl">🎯</div>
            <div class="p-6">
              <h3 class="font-bold text-lg text-white mb-1 group-hover:text-blue-300 transition line-clamp-2"><%= course.title %></h3>
              <p class="text-sm text-slate-400 mb-2">👨‍🏫 <%= course.instructor_name %></p>
              <p class="text-slate-300 text-sm mb-4 line-clamp-2"><%= course.description %></p>
              <% if current_user %>
                <%= button_to "수강신청", enroll_api_v1_course_path(course), method: :post, class: "w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold transition" %>
              <% else %>
                <button onclick="alert('로그인이 필요합니다')" class="w-full px-4 py-2 bg-slate-600 text-white rounded font-semibold">수강신청</button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      </section>

      <!-- 내 강의 -->
      <section id="my-courses" hidden>
        <h2 class="text-2xl font-bold text-white mb-6">내 강의</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% current_user.enrolled_courses.each do |course| %>
            <div class="bg-slate-800 border border-green-500/30 rounded-lg p-6">
              <h3 class="font-bold text-lg text-white mb-2"><%= course.title %></h3>
              <p class="text-sm text-slate-400 mb-2">👨‍🏫 <%= course.instructor_name %></p>
              <p class="text-slate-300 text-sm"><%= course.description %></p>
            </div>
          <% end %>
        </div>
        <% if current_user.enrolled_courses.empty? %>
          <div class="text-center py-12">
            <p class="text-slate-400 mb-4">아직 수강하는 강의가 없습니다.</p>
            <a href="#" onclick="showTab('browse')" class="text-blue-400 hover:text-blue-300">강의 탐색하기</a>
          </div>
        <% end %>
      </section>

      <!-- 진도 -->
      <section id="progress" hidden>
        <h2 class="text-2xl font-bold text-white mb-6">학습 진도</h2>
        <% if current_user.enrolled_courses.any? %>
          <div class="space-y-6">
            <% current_user.enrolled_courses.each do |course| %>
              <% total = course.lectures.count %>
              <% watched = current_user.progresses.where(lecture_id: course.lecture_ids, watched: true).count %>
              <% rate = total.zero? ? 0 : ((watched.to_f / total) * 100).round %>
              <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
                <h3 class="font-bold text-lg text-white mb-2"><%= course.title %></h3>
                <div class="flex items-center gap-3 mb-4">
                  <div class="flex-1 bg-slate-700 rounded-full h-3 overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-500 to-cyan-500 h-full" style="width: <%= rate %>%"></div>
                  </div>
                  <span class="text-sm font-semibold text-blue-400"><%= rate %>%</span>
                </div>
                <p class="text-xs text-slate-400"><%= watched %> / <%= total %> 강의 수강</p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-12">
            <p class="text-slate-400">수강한 강의가 없어 진도 정보가 없습니다.</p>
          </div>
        <% end %>
      </section>
    <% end %>

    <!-- 로그인/가입 패널 (비로그인 시) -->
    <% unless current_user %>
      <section id="auth-panel" class="mt-12 bg-slate-800 border border-slate-700 rounded-lg p-8 max-w-md mx-auto">
        <h2 class="text-2xl font-bold text-white mb-6 text-center">SpeakFlow에 가입하세요</h2>
        
        <!-- 로그인 폼 -->
        <%= form_with url: api_v1_auth_login_path, method: :post, local: true, class: "space-y-4 mb-6" do |f| %>
          <%= f.email_field :email, placeholder: "이메일", value: "instructor@speakflow.kr", class: "w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded text-white placeholder-slate-400" %>
          <%= f.password_field :password, placeholder: "비밀번호", value: "password123", class: "w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded text-white placeholder-slate-400" %>
          <%= f.submit "로그인", class: "w-full px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold transition" %>
        <% end %>

        <div class="divider text-center text-slate-400 my-6">또는</div>

        <!-- 회원가입 폼 -->
        <%= form_with url: api_v1_auth_signup_path, method: :post, local: true, class: "space-y-4" do |f| %>
          <%= f.text_field :name, placeholder: "이름", class: "w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded text-white placeholder-slate-400" %>
          <%= f.email_field :email, placeholder: "이메일", class: "w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded text-white placeholder-slate-400" %>
          <%= f.password_field :password, placeholder: "비밀번호", class: "w-full px-4 py-2 bg-slate-700 border border-slate-600 rounded text-white placeholder-slate-400" %>
          <%= f.submit "회원가입", class: "w-full px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded font-semibold transition" %>
        <% end %>
      </section>
    <% end %>
  </main>

  <script>
    function showTab(tab) {
      document.getElementById('browse').hidden = tab !== 'browse';
      document.getElementById('my-courses').hidden = tab !== 'my-courses';
      document.getElementById('progress').hidden = tab !== 'progress';
    }
  </script>
</body>
</html>

