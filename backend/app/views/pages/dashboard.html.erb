<% content_for :title, "SpeakFlow | Dashboard" %>

<% if current_user %>
  <% initial_tab = params[:tab].presence_in(%w[browse my-courses progress]) || "browse" %>
  <% enrolled_courses = current_user.enrolled_courses.includes(:category, :lectures) %>
  <% enrolled_ids = enrolled_courses.map(&:id) %>
  <% overall = overall_progress_stats(current_user) %>

  <main class="page">
    <section class="hero-shell">
      <div class="hero-shell__ambient" aria-hidden="true"></div>

      <div class="container hero-shell__grid">
        <div class="hero-shell__copy">
          <p class="eyebrow">Personalized speaking dashboard</p>
          <h1 class="hero-shell__title"><%= current_user.name %>님, 환영합니다</h1>
          <p class="hero-shell__body">
            오늘도 SpeakFlow와 함께 말하기 학습을 이어가 보세요.
          </p>

          <div class="button-row">
            <%= link_to "강의 둘러보기", courses_path, class: "button button--primary" %>
            <%= link_to "내 강의 보기", my_courses_path, class: "button button--secondary" %>
          </div>

          <div class="hero-stats">
            <article class="stat-card">
              <span class="stat-card__value"><%= @courses.count %></span>
              <span class="stat-card__label">열려 있는 강의</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:courses_count] %></span>
              <span class="stat-card__label">수강 중인 강의</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:rate] %>%</span>
              <span class="stat-card__label">전체 진도율</span>
            </article>
          </div>
        </div>

        <aside class="hero-focus">
          <div class="hero-focus__glow" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

          <div class="hero-focus__content">
            <div class="hero-focus__logo">
              <%= image_tag "ripple-logo.png", alt: "SpeakFlow ripple logo" %>
            </div>
            <span class="pill pill--accent">오늘의 흐름</span>
            <strong><%= enrolled_courses.first&.title || "내 강의를 먼저 둘러보세요." %></strong>
            <p>
              <% if enrolled_courses.any? %>
                최근 수강 중인 강의와 진도 흐름을 이어서 확인할 수 있습니다.
              <% else %>
                아직 수강 중인 강의가 없다면 먼저 강의 목록에서 관심 있는 과정을 골라보세요.
              <% end %>
            </p>
          </div>
        </aside>
      </div>
    </section>

    <section class="surface">
      <div class="container surface__inner" data-controller="tabs" data-tabs-initial-value="<%= initial_tab %>">
        <div class="tab-bar">
          <button type="button" class="tab-button" data-tabs-target="button" data-tab-id="browse" data-action="tabs#switch">강의 탐색</button>
          <button type="button" class="tab-button" data-tabs-target="button" data-tab-id="my-courses" data-action="tabs#switch">내 강의</button>
          <button type="button" class="tab-button" data-tabs-target="button" data-tab-id="progress" data-action="tabs#switch">진도</button>
        </div>

        <section class="page-section" data-tabs-target="panel" data-tab-panel="browse">
          <div class="section-heading">
            <h2 class="section-title">강의 탐색</h2>
            <p class="section-copy">카테고리별로 과정을 둘러보고 상세 페이지에서 커리큘럼을 확인할 수 있습니다.</p>
          </div>

          <div class="chip-row" style="margin-bottom: 22px;">
            <%= link_to "전체", root_path, class: "category-filter #{params[:category].blank? ? 'is-active' : ''}" %>
            <% @categories.each do |category| %>
              <%= link_to category.name, root_path(category: category.id), class: "category-filter #{params[:category] == category.id.to_s ? 'is-active' : ''}" %>
            <% end %>
          </div>

          <div class="course-grid">
            <% @courses.each do |course| %>
              <article class="course-card">
                <div class="course-card__top">
                  <div>
                    <span class="pill"><%= course.category.name %></span>
                    <h3 style="margin-top: 14px;"><%= course.title %></h3>
                  </div>

                  <span class="micro-ripple" aria-hidden="true">
                    <span class="micro-ripple__ring micro-ripple__ring--a"></span>
                    <span class="micro-ripple__ring micro-ripple__ring--b"></span>
                    <span class="micro-ripple__ring micro-ripple__ring--c"></span>
                    <span class="micro-ripple__core"></span>
                  </span>
                </div>

                <p><%= truncate(course.description, length: 130) %></p>

                <div class="meta-list">
                  <div class="meta-item"><span>강사</span><strong><%= course.instructor_name %></strong></div>
                  <div class="meta-item"><span>강의 수</span><strong><%= course.lectures.count %>개</strong></div>
                  <div class="meta-item"><span>개강일</span><strong><%= display_date(course.start_date) %></strong></div>
                </div>

                <div class="button-row">
                  <%= link_to "상세 보기", course_detail_path(course), class: "button button--secondary button--small" %>
                  <% if enrolled_ids.include?(course.id) %>
                    <span class="pill pill--accent">수강 중</span>
                  <% end %>
                </div>
              </article>
            <% end %>
          </div>
        </section>

        <section class="page-section" data-tabs-target="panel" data-tab-panel="my-courses" hidden>
          <div class="section-heading">
            <h2 class="section-title">내 강의</h2>
            <p class="section-copy">현재 수강 중인 강의와 진행 상태를 한 번에 확인합니다.</p>
          </div>

          <% if enrolled_courses.any? %>
            <div class="course-grid">
              <% enrolled_courses.each do |course| %>
                <% stats = course_progress_stats(current_user, course) %>
                <article class="course-card">
                  <div class="course-card__top">
                    <div>
                      <span class="pill pill--accent">수강 중</span>
                      <h3 style="margin-top: 14px;"><%= course.title %></h3>
                    </div>

                    <span class="orb-ripple" aria-hidden="true">
                      <span class="orb-ripple__ring orb-ripple__ring--a"></span>
                      <span class="orb-ripple__ring orb-ripple__ring--b"></span>
                      <span class="orb-ripple__ring orb-ripple__ring--c"></span>
                      <span class="orb-ripple__core"></span>
                    </span>
                  </div>

                  <p><%= truncate(course.description, length: 130) %></p>

                  <div>
                    <div class="split-between" style="margin-bottom: 8px;">
                      <span class="meta-copy">진도</span>
                      <strong><%= stats[:rate] %>%</strong>
                    </div>
                    <div class="progress-track"><span style="width: <%= stats[:rate] %>%;"></span></div>
                  </div>

                  <div class="meta-list">
                    <div class="meta-item"><span>완료 강의</span><strong><%= stats[:watched] %> / <%= stats[:total] %></strong></div>
                    <div class="meta-item"><span>카테고리</span><strong><%= course.category.name %></strong></div>
                  </div>

                  <div class="button-row">
                    <%= link_to "계속 학습", course_detail_path(course), class: "button button--primary button--small" %>
                  </div>
                </article>
              <% end %>
            </div>
          <% else %>
            <article class="surface-card">
              <h3>아직 수강 중인 강의가 없습니다.</h3>
              <p>강의 목록에서 관심 있는 과정을 먼저 살펴보세요.</p>
              <div class="button-row" style="margin-top: 16px;">
                <%= link_to "강의 둘러보기", courses_path, class: "button button--primary button--small" %>
              </div>
            </article>
          <% end %>
        </section>

        <section class="page-section" data-tabs-target="panel" data-tab-panel="progress" hidden>
          <div class="section-heading">
            <h2 class="section-title">진도</h2>
            <p class="section-copy">강의별 진행률과 전체 학습 현황을 확인합니다.</p>
          </div>

          <div class="stats-grid" style="margin-bottom: 26px;">
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:courses_count] %></span>
              <span class="stat-card__label">수강 중인 강의</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:watched_lectures] %></span>
              <span class="stat-card__label">완료한 강의</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:rate] %>%</span>
              <span class="stat-card__label">전체 진도율</span>
            </article>
          </div>

          <div class="progress-grid">
            <% enrolled_courses.each do |course| %>
              <% stats = course_progress_stats(current_user, course) %>
              <article class="surface-card">
                <h3><%= course.title %></h3>
                <p style="margin-top: 12px;"><%= course.instructor_name %> 강사의 과정입니다.</p>
                <div style="margin-top: 18px;">
                  <div class="split-between" style="margin-bottom: 8px;">
                    <span class="meta-copy">완료율</span>
                    <strong><%= stats[:rate] %>%</strong>
                  </div>
                  <div class="progress-track"><span style="width: <%= stats[:rate] %>%;"></span></div>
                </div>
                <div class="meta-list" style="margin-top: 18px;">
                  <div class="meta-item"><span>완료 강의</span><strong><%= stats[:watched] %>개</strong></div>
                  <div class="meta-item"><span>전체 강의</span><strong><%= stats[:total] %>개</strong></div>
                </div>
              </article>
            <% end %>
          </div>
        </section>
      </div>
    </section>
  </main>
<% else %>
  <% audience_cards = [
    { title: "면접에서 자신 있게 말하고 싶은 분", copy: "자기소개와 답변 구조를 정리하고, 실제 상황에서 떨리지 않게 훈련할 수 있습니다.", image: "/images/landing/audience-01.jpg", image_alt: "면접 스피치 예시" },
    { title: "발표할 때 머릿속이 하얘진 적 있는 분", copy: "전달 순서와 말의 호흡을 익혀 발표 흐름이 끊기지 않도록 돕습니다.", image: "/images/landing/audience-02.jpg", image_alt: "발표 스피치 예시" },
    { title: "목소리와 발성을 다듬고 싶은 분", copy: "발음, 전달력, 보이스 트레이닝 강의를 통해 더 또렷한 목소리를 만들 수 있습니다.", image: "/images/landing/audience-03.jpg", image_alt: "보이스 트레이닝 예시" },
    { title: "일상과 업무에서 설득력 있게 말하고 싶은 분", copy: "커뮤니케이션과 설득 화법 강의를 통해 실전 대화 감각을 키울 수 있습니다.", image: "/images/landing/audience-04.jpg", image_alt: "커뮤니케이션 예시" }
  ] %>
  <% landing_categories = @categories.first(3).map do |category|
       {
         name: category.name,
         description: category.description.presence || "강의 흐름을 둘러보기 위한 카테고리입니다.",
         course_count: category.courses.count,
         path: courses_path(category: category.id)
       }
     end %>
  <% unless landing_categories.any? { |category| category[:name].include?("바디랭귀지") } %>
    <% landing_categories[-1] = {
      name: "바디랭귀지",
      description: "표정, 제스처, 시선 처리까지 함께 다루는 비언어 커뮤니케이션 트랙",
      course_count: 0,
      path: courses_path
    } %>
  <% end %>
  <% recommended_courses = @courses.first(3).each_with_index.map do |course, index|
       {
         course: course,
         price_label: ["월정액 ₩19,000", "월정액 ₩39,000", "월정액 ₩69,000"][index] || "월정액 ₩39,000"
       }
     end %>

  <main class="page">
    <section class="hero-shell hero-shell--landing">
      <div class="hero-shell__ambient" aria-hidden="true"></div>

      <div class="container hero-shell__grid hero-shell__grid--single">
        <div class="hero-shell__copy">
          <p class="eyebrow">Personalized speaking platform</p>
          <h1 class="hero-shell__title">스피치 강의는 SpeakFlow.</h1>
          <p class="hero-shell__body">
            인강 뿐만 아니라 1:1 첨삭 등을 포함한 다양한 기능으로 차원이 다른 성장을 경험할 수 있습니다.
          </p>

          <div class="button-row">
            <%= link_to "회원가입하고 시작하기", login_path(signup: true), class: "button button--primary" %>
            <%= link_to "강의 먼저 둘러보기", courses_path, class: "button button--secondary" %>
          </div>

          <div class="hero-stats">
            <article class="stat-card">
              <span class="stat-card__value"><%= @courses.count %></span>
              <span class="stat-card__label">현재 공개 강의</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= @categories.count %></span>
              <span class="stat-card__label">학습 카테고리</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= User.count %></span>
              <span class="stat-card__label">누적 가입 사용자</span>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="surface">
      <div class="container surface__inner">
        <section class="page-section">
          <div class="section-heading">
            <h2 class="section-title">이런 분들께 추천합니다</h2>
            <p class="section-copy">스피치 능력이 부족해 고민인가요? SpeakFlow가 답입니다!</p>
          </div>

          <div class="landing-audience-grid">
            <% audience_cards.each do |card| %>
              <article class="surface-card landing-audience-card">
                <div class="landing-audience-card__media">
                  <% if card[:image].present? %>
                    <%= image_tag card[:image], alt: card[:image_alt] %>
                  <% else %>
                    <span class="micro-ripple" aria-hidden="true">
                      <span class="micro-ripple__ring micro-ripple__ring--a"></span>
                      <span class="micro-ripple__ring micro-ripple__ring--b"></span>
                      <span class="micro-ripple__ring micro-ripple__ring--c"></span>
                      <span class="micro-ripple__core"></span>
                    </span>
                  <% end %>
                </div>
                <h3><%= card[:title] %></h3>
                <p><%= card[:copy] %></p>
              </article>
            <% end %>
          </div>
        </section>

        <section class="page-section">
          <div class="section-heading">
            <h2 class="section-title">카테고리별 학습</h2>
            <p class="section-copy">다양한 카테고리별 강의를 만나보세요.</p>
          </div>

          <div class="category-grid">
            <% landing_categories.first(3).each do |category| %>
              <article class="category-card">
                <div class="category-card__top">
                  <div>
                    <span class="pill"><%= category[:course_count] %>개 코스</span>
                    <h3 style="margin-top: 14px;"><%= category[:name] %></h3>
                  </div>

                  <span class="micro-ripple" aria-hidden="true">
                    <span class="micro-ripple__ring micro-ripple__ring--a"></span>
                    <span class="micro-ripple__ring micro-ripple__ring--b"></span>
                    <span class="micro-ripple__ring micro-ripple__ring--c"></span>
                    <span class="micro-ripple__core"></span>
                  </span>
                </div>

                <p><%= category[:description] %></p>
                <div class="button-row" style="margin-top: 18px;">
                  <%= link_to "이 카테고리 보기", category[:path], class: "button button--secondary button--small" %>
                </div>
              </article>
            <% end %>
          </div>
        </section>

        <section class="page-section">
          <div class="section-heading">
            <h2 class="section-title">추천 강의</h2>
            <p class="section-copy">SpeakFlow를 대표하는 인기 강사들의 강의를 만나보세요.</p>
          </div>

          <div class="course-grid">
            <% recommended_courses.each do |entry| %>
              <% course = entry[:course] %>
              <article class="course-card">
                <div class="course-card__top">
                  <div>
                    <span class="pill"><%= course.category.name %></span>
                    <h3 style="margin-top: 14px;"><%= course.title %></h3>
                    <p class="meta-copy" style="margin-top: 10px;"><%= course.instructor_name %></p>
                  </div>

                  <span class="orb-ripple" aria-hidden="true">
                    <span class="orb-ripple__ring orb-ripple__ring--a"></span>
                    <span class="orb-ripple__ring orb-ripple__ring--b"></span>
                    <span class="orb-ripple__ring orb-ripple__ring--c"></span>
                    <span class="orb-ripple__core"></span>
                  </span>
                </div>

                <p class="landing-course-price"><%= entry[:price_label] %></p>

                <div class="button-row">
                  <%= link_to "상세 보기", course_detail_path(course), class: "button button--secondary button--small" %>
                </div>
              </article>
            <% end %>
          </div>
        </section>
      </div>
    </section>
  </main>
<% end %>
