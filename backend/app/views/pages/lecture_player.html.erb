<% content_for :title, "#{@lecture.title} | SpeakFlow" %>

<% embed_url = youtube_embed_url(@lecture.video_url) %>

<main class="page"
  data-controller="lecture-player"
  data-lecture-player-lecture-id-value="<%= @lecture.id %>"
  data-lecture-player-progress-url-value="<%= current_user ? progress_api_v1_lecture_path(@lecture) : '' %>">

  <section class="hero-shell">
    <div class="hero-shell__ambient" aria-hidden="true"></div>

    <div class="container hero-shell__grid">
      <div class="hero-shell__copy">
        <p class="eyebrow">Lecture player</p>
        <h1 class="hero-shell__title"><%= @lecture.order_no %>. <%= @lecture.title %></h1>
        <p class="hero-shell__body">
          <%= @course.title %> 안에서 현재 듣고 있는 강의입니다. 시청, 메모, 녹음, 복기가 하나의 흐름으로 이어집니다.
        </p>

        <div class="button-row">
          <%= link_to "과정으로 돌아가기", course_detail_path(@course), class: "button button--secondary" %>
          <% if current_user %>
            <button type="button" class="button button--primary" data-lecture-player-target="watchButton" data-action="lecture-player#markWatched">
              시청 완료 표시
            </button>
          <% else %>
            <%= link_to "로그인 후 진도 저장", login_path, class: "button button--primary" %>
          <% end %>
        </div>
      </div>

      <aside class="hero-focus">
        <div class="hero-focus__glow" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

        <div class="hero-focus__content">
          <span class="pill pill--accent">Playback cue</span>
          <strong>현재 강의는 <%= duration_label(@lecture.duration) %> 분량입니다.</strong>
          <p>핵심 시청 화면은 가운데 두고, 메모와 녹음은 그 바깥 레이어로 배치했습니다.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface">
    <div class="container surface__inner">
      <section class="page-section">
        <div class="lesson-layout">
          <div style="display: grid; gap: 18px;">
            <article class="surface-card">
              <div class="video-frame">
                <% if embed_url.present? %>
                  <iframe
                    src="<%= embed_url %>"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen></iframe>
                <% else %>
                  <div class="video-fallback">아직 영상이 연결되지 않았습니다.</div>
                <% end %>
              </div>
            </article>

            <article class="surface-card">
              <h3>학습 메모</h3>
              <p style="margin-top: 12px;">중심 메시지, 말의 속도, 강조 포인트를 바로 기록해 두세요.</p>
              <div class="field" style="margin-top: 16px;">
                <textarea data-lecture-player-target="notes" placeholder="강의 메모를 적어 보세요."></textarea>
              </div>
              <div class="button-row" style="margin-top: 14px;">
                <button type="button" class="button button--primary button--small" data-action="lecture-player#saveNotes">메모 저장</button>
                <button type="button" class="button button--secondary button--small" data-action="lecture-player#clearNotes">메모 비우기</button>
              </div>
              <div data-lecture-player-target="status" class="status-banner" hidden></div>
            </article>

            <article class="surface-card">
              <h3>말하기 녹음 연습</h3>
              <p style="margin-top: 12px;">강의 내용을 자기 말로 다시 말해 보면서 전달력을 복기할 수 있습니다.</p>
              <div class="recording-actions" style="margin-top: 16px;">
                <button type="button" class="button button--primary button--small" data-lecture-player-target="recordButton" data-action="lecture-player#startRecording">녹음 시작</button>
                <button type="button" class="button button--secondary button--small" data-lecture-player-target="stopButton" data-action="lecture-player#stopRecording" disabled>녹음 중지</button>
                <button type="button" class="button button--secondary button--small" data-lecture-player-target="playButton" data-action="lecture-player#playRecording" disabled>재생</button>
                <button type="button" class="button button--secondary button--small" data-lecture-player-target="downloadButton" data-action="lecture-player#downloadRecording" disabled>다운로드</button>
              </div>
              <audio class="audio-player" data-lecture-player-target="audio" controls hidden></audio>
            </article>
          </div>

          <div style="display: grid; gap: 18px;">
            <article class="summary-panel">
              <span class="pill">Course context</span>
              <h3 style="margin-top: 14px;"><%= @course.title %></h3>
              <p style="margin-top: 14px;">강사 <%= @course.instructor_name %> · 전체 강의 <%= @course.lectures.count %>개</p>
            </article>

            <article class="surface-card">
              <div class="section-heading" style="margin-bottom: 18px;">
                <h2 class="section-title" style="font-size: 28px;">전체 강의 흐름</h2>
                <p class="section-copy">현재 강의는 강조하고, 완료한 강의는 라임 포인트로 남깁니다.</p>
              </div>

              <div class="lecture-list">
                <% @course.lectures.order(:order_no).each do |lecture| %>
                  <% complete = watched?(current_user, lecture) %>
                  <article
                    class="lecture-card <%= 'is-current' if lecture.id == @lecture.id %> <%= 'is-complete' if complete %>"
                    data-lecture-row-id="<%= lecture.id %>">
                    <div class="lecture-card__top">
                      <div style="display: flex; gap: 14px; align-items: flex-start;">
                        <span class="lecture-badge <%= 'is-complete' if complete %>" data-lecture-badge-id="<%= lecture.id %>"><%= lecture.order_no %></span>
                        <div>
                          <h3><%= lecture.title %></h3>
                          <p style="margin-top: 10px;"><%= duration_label(lecture.duration) %></p>
                        </div>
                      </div>

                      <% if lecture.id == @lecture.id %>
                        <span class="pill pill--accent">현재 재생</span>
                      <% else %>
                        <%= link_to "열기", lecture_player_path(lecture), class: "button button--secondary button--small" %>
                      <% end %>
                    </div>
                  </article>
                <% end %>
              </div>
            </article>
          </div>
        </div>
      </section>
    </div>
  </section>
</main>
