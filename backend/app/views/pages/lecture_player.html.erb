<% content_for :title, "SpeakFlow | 강의 시청" %>
<% embed_url = youtube_embed_url(@current_lecture&.video_url) %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <% if @current_lecture %>
      <section class="hero">
        <div class="hero-grid lecture-layout">
          <div>
            <div class="eyebrow"><%= @current_lecture.order_no %>강</div>
            <h2><%= @current_lecture.title %></h2>
            <p>현재 강의를 시청하고 학습 진행 상태를 이어갈 수 있습니다.</p>
            <div class="badge-row">
              <span class="badge"><%= watched_label(@demo_user, @current_lecture) %></span>
              <span class="badge">재생 시간 <%= duration_label(@current_lecture.duration) %></span>
            </div>
            <div class="hero-actions">
              <% if @current_lecture.video_url.present? %>
                <%= link_to "YouTube에서 보기", @current_lecture.video_url, class: "link-btn primary", target: "_blank", rel: "noreferrer" %>
              <% end %>
              <button class="btn" type="button" disabled>시청 완료 저장</button>
            </div>
          </div>
          <aside class="preview-panel">
            <% if embed_url %>
              <div class="video-embed-wrap">
                <iframe class="video-embed" src="<%= embed_url %>" title="<%= @current_lecture.title %>" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
              </div>
            <% else %>
              <div class="video">
                <div class="preview-play">▶</div>
                <div>
                  <div class="video-title">강의 영상</div>
                  <p class="small-note"><%= @current_lecture.video_url %></p>
                </div>
              </div>
            <% end %>
          </aside>
        </div>
      </section>

      <article class="card">
        <h3>커리큘럼</h3>
        <table class="table">
          <tr><th>순서</th><th>강의명</th><th>재생 시간</th><th>학습 상태</th><th></th></tr>
          <% @curriculum.each do |lecture| %>
            <tr>
              <td><%= lecture.order_no %></td>
              <td><%= lecture.title %></td>
              <td><%= duration_label(lecture.duration) %></td>
              <td><%= watched_label(@demo_user, lecture) %></td>
              <td><%= link_to "시청", lecture_player_path(course_id: lecture.course_id, lecture_id: lecture.id), class: "table-link" %></td>
            </tr>
          <% end %>
        </table>
      </article>
    <% else %>
      <article class="empty">표시할 강의가 없습니다.</article>
    <% end %>
  </section>
</main>
