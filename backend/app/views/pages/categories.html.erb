<% content_for :title, "SpeakFlow | 카테고리" %>

<main class="page">
  <section class="hero-shell">
    <div class="hero-shell__ambient" aria-hidden="true"></div>

    <div class="container hero-shell__grid">
      <div class="hero-shell__copy">
        <p class="eyebrow">카테고리 맵</p>
        <h1 class="hero-shell__title">어떤 상황이어도<br>SpeakFlow면 됩니다.</h1>
        <p class="hero-shell__body">
          목소리, 바디랭귀지, 표현력 부족 등 고민은 이제 그만!
        </p>
      </div>

      <aside class="hero-focus">
        <div class="hero-focus__glow" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
        <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

        <div class="hero-focus__content">
          <span class="pill pill--accent">카테고리 현황</span>
          <strong><%= @categories.count %>개의 카테고리가 준비되어 있습니다.</strong>
          <p>발표, 면접, 전달력 향상처럼 맥락이 다른 만큼 시작점도 분명해야 합니다.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="surface">
    <div class="container surface__inner">
      <section class="page-section">
        <div class="category-grid">
          <% @categories.each do |category| %>
            <article class="category-card">
              <div class="category-card__top">
                <div>
                  <span class="pill"><%= category.courses.count %>개 코스</span>
                  <h3 style="margin-top: 14px;"><%= category.name %></h3>
                </div>

                <span class="micro-ripple" aria-hidden="true">
                  <span class="micro-ripple__ring micro-ripple__ring--a"></span>
                  <span class="micro-ripple__ring micro-ripple__ring--b"></span>
                  <span class="micro-ripple__ring micro-ripple__ring--c"></span>
                  <span class="micro-ripple__core"></span>
                </span>
              </div>

              <p><%= category.description.presence || "목적이 비슷한 학습 과정을 하나의 흐름으로 모아 둔 카테고리입니다." %></p>

              <div class="button-row" style="margin-top: 18px;">
                <%= link_to "강의 보기", courses_path(category: category.id), class: "button button--secondary button--small" %>
              </div>
            </article>
          <% end %>
        </div>
      </section>
    </div>
  </section>
</main>
