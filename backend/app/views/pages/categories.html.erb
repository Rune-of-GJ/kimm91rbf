<% content_for :title, "SpeakFlow | 카테고리" %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <section class="hero">
      <div class="hero-grid">
        <div>
          <div class="eyebrow">카테고리 탐색</div>
          <h2>배우고 싶은 주제부터<br>먼저 고르세요.</h2>
          <p>주제별로 강의를 나눠 두었습니다. 카테고리를 선택하면 해당 강의 목록으로 이동합니다.</p>
        </div>
        <aside class="preview-panel">
          <div class="preview-screen">
            <div>
              <div class="section-title">전체 카테고리</div>
              <p>현재 등록된 분류를 한 번에 확인할 수 있습니다.</p>
            </div>
            <div class="floating-card">
              <strong><%= @categories.size %>개 카테고리</strong>
              <div class="small-note">강의가 있는 항목만 바로 이동 가능</div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <% if @categories.any? %>
      <section class="grid-3">
        <% @categories.each do |category| %>
          <% course_count = category.courses.size %>
          <article class="card">
            <h3><%= category.name %></h3>
            <p><%= category.description.presence || "카테고리 설명이 준비 중입니다." %></p>
            <div class="badge-row">
              <span class="badge">강의 <%= course_count %>개</span>
            </div>
            <div class="btn-row">
              <% if course_count.positive? %>
                <%= link_to "강의 보기", courses_path(category_id: category.id), class: "link-btn primary" %>
              <% else %>
                <button class="btn" type="button" disabled>준비 중</button>
              <% end %>
            </div>
          </article>
        <% end %>
      </section>
    <% else %>
      <article class="empty">등록된 카테고리가 없습니다.</article>
    <% end %>
  </section>
</main>
