<% content_for :title, "카테고리 | SpeakFlow" %>

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>카테고리 | SpeakFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-slate-900 via-blue-900 to-slate-900 text-white">
  <!-- 헤더 -->
  <header class="sticky top-0 z-50 border-b border-blue-500/20 bg-slate-900/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <%= link_to "🎤 SpeakFlow", root_path, class: "text-2xl font-black text-blue-400 no-underline" %>
      </div>
      <div class="flex items-center gap-4">
        <% if current_user %>
          <span class="text-sm text-blue-300"><%= current_user.name %></span>
          <%= button_to "로그아웃", api_v1_auth_logout_path, method: :post, class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded font-medium transition" %>
        <% else %>
          <%= link_to "로그인", root_path, class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-medium transition no-underline" %>
        <% end %>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-black text-white mb-8">강의 카테고리</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @categories.each do |category| %>
        <div class="bg-slate-800 border border-slate-700 hover:border-blue-500 rounded-lg p-6 transition group cursor-pointer">
          <div class="text-5xl mb-4">📚</div>
          <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-blue-300"><%= category.name %></h2>
          <p class="text-slate-300 mb-4"><%= category.courses.count %>개의 강의</p>
          <%= link_to "강의 보기", courses_path(category: category.id), class: "inline-block px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold transition no-underline" %>
        </div>
      <% end %>
    </div>
  </main>
</body>
</html>
