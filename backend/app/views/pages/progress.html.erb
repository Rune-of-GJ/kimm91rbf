<% content_for :title, "SpeakFlow | 진도 관리" %>

<main class="shell">
  <header class="topbar">
    <h1 class="brand"><%= link_to "SpeakFlow", root_path %></h1>
  </header>

  <section class="content">
    <%= page_links(@active_page) %>

    <section class="hero">
      <div class="eyebrow">진도 확인</div>
      <h2>코스별 진행 상황을<br>한 번에 확인하세요.</h2>
      <p>수강 중인 코스의 전체 진행률과 각 강의의 시청 상태를 볼 수 있습니다.</p>
    </section>

    <% if @my_courses.any? %>
      <section class="grid-2">
        <article class="card">
          <h3>코스별 진도</h3>
          <table class="table">
            <tr><th>강의명</th><th>완료 수</th><th>진행률</th></tr>
            <% @my_courses.each do |course| %>
              <% stats = course_progress_stats(@demo_user, course) %>
              <tr><td><%= course.title %></td><td><%= stats[:watched] %> / <%= stats[:total] %></td><td><%= stats[:rate] %>%</td></tr>
            <% end %>
          </table>
        </article>

        <article class="card">
          <h3>강의별 상태</h3>
          <table class="table">
            <tr><th>순서</th><th>강의명</th><th>상태</th><th>완료 시각</th></tr>
            <% @my_courses.first.lectures.each do |lecture| %>
              <% progress = @demo_user&.progresses&.find_by(lecture: lecture) %>
              <tr><td><%= lecture.order_no %></td><td><%= lecture.title %></td><td><%= progress&.watched ? "시청 완료" : "미시청" %></td><td><%= display_value(progress&.watched_at) %></td></tr>
            <% end %>
          </table>
        </article>
      </section>
    <% else %>
      <article class="empty">표시할 진도 데이터가 없습니다.</article>
    <% end %>
  </section>
</main>
