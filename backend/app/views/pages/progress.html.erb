<% content_for :title, "진도 | SpeakFlow" %>

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>진도 | SpeakFlow</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-slate-800 via-slate-700 to-slate-800 text-white">
  <!-- 헤더 -->
  <header class="sticky top-0 z-50 border-b border-blue-500/20 bg-slate-900/95 backdrop-blur">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <%= link_to root_path, class: "text-2xl font-black text-blue-400 no-underline" do %>
          <div class="flex flex-col items-center">
            <img src="/speak.png" alt="SpeakFlow" class="h-16 w-auto">
            <span class="text-slate-400 text-sm mt-1">발표 능력 향상 플랫폼</span>
          </div>
        <% end %>
      </div>
      <div class="flex items-center gap-4">
        <% if current_user %>
          <button onclick="toggleSidebar()" class="text-white hover:text-blue-300 transition">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        <% else %>
          <%= link_to "로그인/가입", login_path, class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-medium transition" %>
        <% end %>
      </div>
    </div>
  </header>

  <main class="bg-slate-800 min-h-screen">
    <div class="max-w-7xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-black text-white mb-8">학습 진도</h1>

    <% if current_user.enrolled_courses.any? %>
      <div class="space-y-6">
        <% current_user.enrolled_courses.each do |course| %>
          <% total = course.lectures.count %>
          <% watched = current_user.progresses.where(lecture_id: course.lecture_ids, watched: true).count %>
          <% rate = total.zero? ? 0 : ((watched.to_f / total) * 100).round %>
          
          <div class="bg-slate-800 border border-slate-700 rounded-lg p-6 hover:border-blue-500 transition">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="font-bold text-xl text-white mb-1"><%= course.title %></h3>
                <p class="text-sm text-slate-400">👨‍🏫 <%= course.instructor_name %></p>
              </div>
              <span class="text-2xl font-black text-blue-400"><%= rate %>%</span>
            </div>

            <!-- 진도 바 -->
            <div class="mb-4">
              <div class="w-full bg-slate-700 rounded-full h-4 overflow-hidden">
                <div class="bg-gradient-to-r from-blue-500 to-cyan-500 h-full transition-all duration-500" style="width: <%= rate %>%"></div>
              </div>
            </div>

            <!-- 강의 목록 -->
            <div class="mb-4">
              <div class="text-sm text-slate-400 mb-3">
                <span class="font-semibold text-white"><%= watched %></span>
                <span> / </span>
                <span class="font-semibold text-white"><%= total %></span>
                <span> 강의 완료</span>
              </div>
              
              <div class="space-y-2 max-h-48 overflow-y-auto">
                <% course.lectures.order(:order_no).each do |lecture| %>
                  <% is_watched = current_user.progresses.find_by(lecture_id: lecture.id, watched: true).present? %>
                  <div class="flex items-center gap-3 p-2 rounded bg-slate-700/50 hover:bg-slate-700 transition">
                    <div class="text-lg"><%= is_watched ? "✅" : "⭕" %></div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-white truncate"><%= lecture.title %></p>
                      <p class="text-xs text-slate-400"><%= lecture.duration_minutes || 0 %>분</p>
                    </div>
                    <% if is_watched %>
                      <span class="text-xs font-semibold text-green-400">완료</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>

            <%= link_to "강의 계속 보기", course_detail_path(course_id: course.id), class: "inline-block px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold transition no-underline" %>
          </div>
        <% end %>

        <!-- 전체 진도 요약 -->
        <div class="bg-gradient-to-r from-blue-600 to-cyan-600 rounded-lg p-6 mt-8">
          <h2 class="text-2xl font-bold text-white mb-4">종합 진도</h2>
          <% total_lectures = current_user.enrolled_courses.sum { |c| c.lectures.count } %>
          <% total_watched = current_user.progresses.where(watched: true).count %>
          <% total_rate = total_lectures.zero? ? 0 : ((total_watched.to_f / total_lectures) * 100).round %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-slate-100 mb-2">전체 강의: <span class="font-bold text-lg"><%= total_lectures %></span>개</p>
              <p class="text-slate-100">완료한 강의: <span class="font-bold text-lg"><%= total_watched %></span>개</p>
            </div>
            <div class="text-right">
              <p class="text-5xl font-black text-white"><%= total_rate %>%</p>
              <p class="text-slate-100">완성도</p>
            </div>
          </div>
        </div>
      </div>
    <% else %>
      <div class="text-center py-16 bg-slate-800/50 rounded-lg border border-slate-700">
        <p class="text-2xl text-slate-400 mb-4">아직 수강하는 강의가 없습니다.</p>
        <%= link_to "강의 탐색하기", courses_path, class: "inline-block px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded font-semibold transition no-underline" %>
      </div>
    <% end %>
    </div>
  </main>

  <!-- 사용자 사이드바 -->
  <% if current_user %>
    <div id="user-sidebar" class="fixed inset-y-0 right-0 z-50 w-64 bg-slate-800 border-l border-slate-700 transform translate-x-full transition-transform duration-300 ease-in-out">
      <div class="p-6">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-white">메뉴</h3>
          <button onclick="toggleSidebar()" class="text-slate-400 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <div class="space-y-4">
          <div class="text-center">
            <p class="text-blue-300 font-semibold"><%= current_user.name %> 님</p>
            <p class="text-slate-400 text-sm"><%= current_user.email %></p>
          </div>
          <div class="border-t border-slate-700 pt-4">
            <button onclick="logout()" class="w-full px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded font-medium transition">
              로그아웃
            </button>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <script>
    function toggleSidebar() {
      const sidebar = document.getElementById('user-sidebar');
      sidebar.classList.toggle('translate-x-full');
    }

    async function logout() {
      try {
        await fetch('/api/v1/auth/logout', {
          method: 'POST',
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
          }
        });
        window.location.href = '/';
      } catch (error) {
        console.error('Logout error:', error);
        window.location.href = '/';
      }
    }
  </script>
</body>
</html>
