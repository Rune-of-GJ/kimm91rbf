<% content_for :title, "SpeakFlow | 진도" %>

<main class="page">
  <% if current_user %>
    <% enrolled_courses = current_user.learning_courses %>
    <% overall = overall_progress_stats(current_user) %>

    <section class="hero-shell">
      <div class="hero-shell__ambient" aria-hidden="true"></div>

      <div class="container hero-shell__grid">
        <div class="hero-shell__copy">
          <p class="eyebrow">Progress tracking</p>
          <h1 class="hero-shell__title">나의 수강 진도 한눈에 보기.</h1>
          <p class="hero-shell__body">수강 중인 강의들의 완료 상황을 한눈에 확인하세요.</p>
        </div>

        <aside class="hero-focus">
          <div class="hero-focus__glow" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--a" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--b" aria-hidden="true"></div>
          <div class="hero-focus__ring hero-focus__ring--c" aria-hidden="true"></div>

          <div class="hero-focus__content">
            <span class="pill pill--accent">Overall progress</span>
            <strong><%= overall[:rate] %>% 완료</strong>
            <p><%= overall[:watched_lectures] %>개의 강의를 끝냈고, 총 <%= overall[:total_lectures] %>개 강의가 흐름 안에 들어와 있습니다.</p>
          </div>
        </aside>
      </div>
    </section>

    <section class="surface">
      <div class="container surface__inner">
        <section class="page-section">
          <div class="stats-grid">
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:courses_count] %></span>
              <span class="stat-card__label">수강 과정 수</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:total_lectures] %></span>
              <span class="stat-card__label">전체 강의 수</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:watched_lectures] %></span>
              <span class="stat-card__label">완료한 강의 수</span>
            </article>
            <article class="stat-card">
              <span class="stat-card__value"><%= overall[:rate] %>%</span>
              <span class="stat-card__label">누적 완료율</span>
            </article>
          </div>
        </section>

        <section class="page-section">
          <div class="section-heading">
            <h2 class="section-title">과정별 세부 진도</h2>
            <p class="section-copy">각 강의의 완료 상황을 확인할 수 있습니다.</p>
          </div>

          <% if enrolled_courses.any? %>
            <div class="progress-grid">
              <% enrolled_courses.each do |course| %>
                <% stats = course_progress_stats(current_user, course) %>
                <article class="surface-card">
                  <h3><%= course.title %></h3>
                  <p style="margin-top: 12px;"><%= course.instructor_name %> 강사의 과정</p>

                  <div style="margin-top: 18px;">
                    <div class="split-between" style="margin-bottom: 8px;">
                      <span class="meta-copy">완료율</span>
                      <strong><%= stats[:rate] %>%</strong>
                    </div>
                    <div class="progress-track"><span style="width: <%= stats[:rate] %>%;"></span></div>
                  </div>

                  <div class="meta-list" style="margin-top: 18px;">
                    <% course.lectures.each do |lecture| %>
                      <div class="meta-item">
                        <span><%= lecture.order_no %>. <%= lecture.title %></span>
                        <strong><%= watched?(current_user, lecture) ? "완료" : "대기" %></strong>
                      </div>
                    <% end %>
                  </div>
                </article>
              <% end %>
            </div>
          <% else %>
            <article class="surface-card">
              <h3>진도를 표시할 과정이 아직 없습니다.</h3>
              <p style="margin-top: 14px;">강의를 먼저 수강하면 여기에 과정별 진도 리포트가 쌓입니다.</p>
            </article>
          <% end %>
        </section>
      </div>
    </section>
  <% else %>
    <section class="hero-shell">
      <div class="container">
        <article class="surface-card">
          <h3>진도 페이지는 로그인 후 확인할 수 있어요.</h3>
          <p style="margin-top: 14px;">학습 상태를 저장하고 다시 보려면 먼저 로그인해 주세요.</p>
          <div class="button-row" style="margin-top: 18px;">
            <%= link_to "로그인", login_path, class: "button button--primary button--small" %>
          </div>
        </article>
      </div>
    </section>
  <% end %>
</main>
