<% content_for :title, "SpeakFlow | 내 멤버십" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "memberships/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">내 멤버십</h1>
              <p class="section-copy">현재 이용 중인 플랜과 첨삭 크레딧, 최근 멤버십 변경 이력을 한 번에 확인할 수 있습니다.</p>
            </div>
          </section>

          <section class="page-section">
            <% if @active_subscription %>
              <div class="detail-grid">
                <article class="surface-card admin-preview-panel">
                  <span class="pill pill--accent">활성 구독</span>
                  <h3><%= @active_subscription.membership_plan.name %></h3>
                  <p><%= @active_subscription.membership_plan.tagline %></p>

                  <div class="meta-list" style="margin-top: 18px;">
                    <div class="meta-item"><span>시작일</span><strong><%= display_date(@active_subscription.started_at.to_date) %></strong></div>
                    <div class="meta-item"><span>다음 결제일</span><strong><%= display_date(@active_subscription.current_period_end.to_date) %></strong></div>
                    <div class="meta-item"><span>월 구독료</span><strong><%= number_to_currency(@active_subscription.membership_plan.monthly_price, unit: "원", precision: 0, format: "%n%u") %></strong></div>
                  </div>

                  <div class="button-row membership-account-actions" style="margin-top: 18px;">
                    <%= link_to "플랜 변경", membership_plans_path, class: "button button--secondary button--small" %>
                    <%= button_to "멤버십 해지", membership_cancel_path, method: :patch, class: "button button--ghost button--small", form_class: "inline-form" %>
                  </div>
                </article>

                <article class="surface-card admin-preview-panel">
                  <span class="pill">첨삭 크레딧</span>
                  <h3><%= @total_coaching_credits %>회 사용 가능</h3>

                  <div class="meta-list" style="margin-top: 18px;">
                    <div class="meta-item"><span>월정액 포함</span><strong><%= @included_coaching_credits %>회</strong></div>
                    <div class="meta-item"><span>별도 구매</span><strong><%= @purchased_coaching_credits %>회</strong></div>
                    <div class="meta-item"><span>총 보유</span><strong><%= @total_coaching_credits %>회</strong></div>
                  </div>

                  <p style="margin-top: 18px;">현재 사용할 수 있는 첨삭 크레딧을 월정액 포함분과 별도 구매분으로 나누어 확인할 수 있습니다.</p>

                  <div class="button-row membership-account-actions" style="margin-top: 18px;">
                    <%= link_to "첨삭권 보러가기", coaching_products_path, class: "button button--secondary button--small" %>
                    <%= link_to "첨삭 요청하기", new_coaching_request_path, class: "button button--primary button--small" %>
                  </div>
                </article>
              </div>
            <% else %>
              <article class="surface-card admin-preview-panel">
                <h3>아직 활성 멤버십이 없습니다.</h3>
                <p style="margin-top: 14px;">원하는 플랜을 선택하고 SpeakFlow 강의와 리허설 기능을 바로 시작해보세요.</p>
                <div class="button-row" style="margin-top: 18px;">
                  <%= link_to "멤버십 시작하기", membership_plans_path, class: "button button--primary" %>
                </div>
              </article>
            <% end %>
          </section>

          <section class="page-section">
            <div class="section-heading">
              <h2 class="section-title">멤버십 기록</h2>
              <p class="section-copy">최근 가입하거나 변경한 멤버십 이력을 확인할 수 있습니다.</p>
            </div>

            <% if @recent_subscriptions.any? %>
              <div class="course-grid">
                <% @recent_subscriptions.each do |subscription| %>
                  <article class="course-card">
                    <span class="pill <%= 'pill--accent' if subscription.active_now? %>"><%= ({ "active" => "활성", "replaced" => "변경됨", "canceled" => "해지됨" }[subscription.status] || subscription.status) %></span>
                    <h3 style="margin-top: 14px;"><%= subscription.membership_plan.name %></h3>
                    <p><%= subscription.membership_plan.tagline %></p>
                    <div class="meta-list">
                      <div class="meta-item"><span>시작일</span><strong><%= display_date(subscription.started_at.to_date) %></strong></div>
                      <div class="meta-item"><span>종료일</span><strong><%= display_date(subscription.current_period_end.to_date) %></strong></div>
                    </div>
                  </article>
                <% end %>
              </div>
            <% end %>
          </section>

          <section class="page-section">
            <div class="section-heading">
              <h2 class="section-title">최근 첨삭 요청</h2>
              <p class="section-copy">최근에 보낸 첨삭 요청과 현재 상태를 빠르게 확인할 수 있습니다.</p>
            </div>

            <% if @recent_feedback_requests.any? %>
              <div class="course-grid">
                <% @recent_feedback_requests.each do |request| %>
                  <article class="course-card">
                    <span class="pill"><%= ({ "queued" => "대기 중", "reviewing" => "검토 중", "completed" => "완료" }[request.status] || request.status) %></span>
                    <h3 style="margin-top: 14px;"><%= request.title %></h3>
                    <p><%= request.credit_label %></p>
                    <div class="meta-list">
                      <div class="meta-item"><span>요청일</span><strong><%= display_date(request.created_at.to_date) %></strong></div>
                      <div class="meta-item"><span>대상 강의</span><strong><%= request.course&.title || "미지정" %></strong></div>
                    </div>
                  </article>
                <% end %>
              </div>
            <% else %>
              <article class="surface-card">
                <h3>아직 첨삭 요청이 없습니다.</h3>
                <p style="margin-top: 14px;">첨삭권이 있다면 음성과 메모를 올려 첨삭 요청을 시작할 수 있습니다.</p>
              </article>
            <% end %>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
