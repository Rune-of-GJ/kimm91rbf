<% content_for :title, "SpeakFlow | Preview Coaching Queue" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/instructor/coaching/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">첨삭 대기열 테스트 페이지</h1>
              <p class="section-copy">
                강사는 먼저 어떤 요청이 들어와 있는지, Coach 포함 요청인지 별도 구매권 요청인지 구분해서 보고 싶어합니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <article class="surface-card admin-preview-panel">
              <span class="pill pill--accent">대기 요청</span>
              <div class="commerce-list">
                <% @queue_items.each do |item| %>
                  <div class="commerce-line">
                    <div>
                      <strong><%= item[:learner] %> · <%= item[:title] %></strong>
                      <span><%= item[:submitted_on].strftime("%Y.%m.%d") %> · <%= item[:source] %></span>
                    </div>
                    <%= link_to "검토 시작", preview_instructor_coaching_review_path, class: "button button--secondary button--small" %>
                  </div>
                <% end %>
              </div>
            </article>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
