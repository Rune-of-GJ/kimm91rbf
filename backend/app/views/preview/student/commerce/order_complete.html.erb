<% content_for :title, "SpeakFlow | Preview Order Complete" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/student/commerce/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">주문 완료 테스트 페이지</h1>
              <p class="section-copy">
                결제 직후 학생이 무엇을 보아야 안심하고, 어떻게 바로 학습으로 이어질지 확인하기 위한 완료 화면입니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <div class="detail-grid">
              <article class="surface-card admin-preview-panel">
                <span class="pill pill--accent">결제 완료</span>
                <h3>구매가 완료되었습니다.</h3>
                <p>주문 즉시 내 강의에 등록되고, 이제부터는 각 강의를 무제한으로 소장하는 흐름을 가정합니다.</p>

                <div class="meta-list">
                  <div class="meta-item"><span>결제 금액</span><strong><%= number_to_currency(@completed_amount, unit: "₩", precision: 0) %></strong></div>
                  <div class="meta-item"><span>구매 강의 수</span><strong><%= @purchased_courses.size %>개</strong></div>
                  <div class="meta-item"><span>등록 정책</span><strong>즉시 내 강의 등록</strong></div>
                </div>

                <div class="button-row">
                  <%= link_to "내 강의로 이동", my_courses_path, class: "button button--primary" %>
                  <%= link_to "주문 내역 시안 보기", preview_student_cart_path, class: "button button--secondary" %>
                </div>
              </article>

              <article class="surface-card admin-preview-panel">
                <span class="pill">바로 시작할 강의</span>
                <div class="commerce-list">
                  <% @purchased_courses.each do |item| %>
                    <div class="commerce-line">
                      <div>
                        <strong><%= item[:course].title %></strong>
                        <span><%= item[:ownership] %></span>
                      </div>
                      <strong><%= number_to_currency(item[:price], unit: "₩", precision: 0) %></strong>
                    </div>
                  <% end %>
                </div>
              </article>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
