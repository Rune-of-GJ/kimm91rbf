<% content_for :title, "SpeakFlow | Preview Paid Course" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/student/commerce/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">유료 강의 상세 테스트 페이지</h1>
              <p class="section-copy">
                학생이 강의 가치를 판단하고 결제 흐름으로 넘어가기 전, 가격과 소장 정책을 어떻게 읽게 할지 보는 시안입니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <div class="detail-grid">
              <article class="surface-card admin-preview-panel">
                <span class="pill pill--accent"><%= @featured_course[:badge] %></span>
                <h3><%= @featured_course[:course].title %></h3>
                <p><%= @featured_course[:course].description %></p>

                <div class="meta-list">
                  <div class="meta-item"><span>강사</span><strong><%= @featured_course[:course].instructor_name %></strong></div>
                  <div class="meta-item"><span>카테고리</span><strong><%= @featured_course[:course].category.name %></strong></div>
                  <div class="meta-item"><span>강의편 수</span><strong><%= @featured_course[:lecture_count] %>개</strong></div>
                  <div class="meta-item"><span>소장 정책</span><strong><%= @featured_course[:ownership] %></strong></div>
                </div>

                <div class="commerce-price">
                  <strong><%= number_to_currency(@featured_course[:price], unit: "₩", precision: 0) %></strong>
                  <span><%= number_to_currency(@featured_course[:original_price], unit: "₩", precision: 0) %></span>
                </div>

                <div class="button-row">
                  <%= link_to "장바구니에 담기", preview_student_cart_path, class: "button button--secondary" %>
                  <%= link_to "바로 결제하기", preview_student_checkout_path, class: "button button--primary" %>
                </div>
              </article>

              <article class="surface-card admin-preview-panel">
                <span class="pill">SpeakFlow다운 판매 포인트</span>
                <div class="admin-preview-checks">
                  <div class="admin-preview-check">
                    <strong>결제 후 무제한 소장</strong>
                    <p>학생이 가장 먼저 안심할 수 있도록, 기간제 접근이 아니라 영구 소장이라는 점을 명확하게 보여줍니다.</p>
                  </div>
                  <div class="admin-preview-check">
                    <strong>리허설 과제와 피드백 포함</strong>
                    <p>그냥 영상 시청이 아니라, 직접 말해보고 피드백받는 SpeakFlow다운 차별점을 상세에서 바로 설득합니다.</p>
                  </div>
                  <div class="admin-preview-check">
                    <strong>추가 구매 유도 포인트</strong>
                    <p>발표 강의와 면접 강의를 함께 담으면 할인되는 번들 제안을 어디에 둘지 확인하기 위한 영역입니다.</p>
                  </div>
                </div>
              </article>
            </div>
          </section>

          <section class="page-section">
            <div class="section-heading">
              <h2 class="section-title" style="font-size: 34px;">함께 구매를 고민할 강의</h2>
              <p class="section-copy">장바구니나 번들 구매를 유도할 때 어떤 강의 카드 구성이 자연스러운지 보는 구간입니다.</p>
            </div>

            <div class="course-grid">
              <% @priced_courses.drop(1).each do |item| %>
                <article class="surface-card admin-preview-panel">
                  <span class="pill"><%= item[:badge] %></span>
                  <h3><%= item[:course].title %></h3>
                  <p><%= item[:support] %></p>
                  <div class="commerce-price commerce-price--compact">
                    <strong><%= number_to_currency(item[:price], unit: "₩", precision: 0) %></strong>
                  </div>
                  <div class="button-row">
                    <%= link_to "담아보기", preview_student_cart_path, class: "button button--secondary button--small" %>
                  </div>
                </article>
              <% end %>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
