<% content_for :title, "SpeakFlow | Preview Checkout" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/student/commerce/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">결제 테스트 페이지</h1>
              <p class="section-copy">
                결제 수단 선택, 주문 요약, 소장 정책 고지까지 한 화면에 어떻게 배치할지 보는 단계입니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <div class="detail-grid">
              <article class="surface-card admin-preview-panel">
                <span class="pill pill--accent">결제 수단</span>
                <div class="commerce-methods">
                  <% @checkout_methods.each_with_index do |method, index| %>
                    <div class="commerce-method <%= 'is-active' if index.zero? %>">
                      <strong><%= method[:label] %></strong>
                      <span><%= method[:note] %></span>
                    </div>
                  <% end %>
                </div>

                <div class="admin-preview-note">
                  <strong>정책 안내</strong>
                  <p>이 강의는 결제 후 무제한 소장되며, 구매 즉시 내 강의에 등록되는 구조를 가정합니다.</p>
                </div>
              </article>

              <article class="summary-panel admin-preview-panel">
                <span class="pill">주문 요약</span>
                <div class="commerce-list">
                  <% @cart_items.each do |item| %>
                    <div class="commerce-line commerce-line--summary">
                      <div>
                        <strong><%= item[:course].title %></strong>
                        <span><%= item[:support] %></span>
                      </div>
                      <strong><%= number_to_currency(item[:price], unit: "₩", precision: 0) %></strong>
                    </div>
                  <% end %>
                </div>

                <div class="meta-list">
                  <div class="meta-item"><span>상품 합계</span><strong><%= number_to_currency(@checkout_subtotal, unit: "₩", precision: 0) %></strong></div>
                  <div class="meta-item"><span>할인 적용</span><strong>-<%= number_to_currency(@checkout_discount, unit: "₩", precision: 0) %></strong></div>
                  <div class="meta-item"><span>최종 결제</span><strong><%= number_to_currency(@checkout_total, unit: "₩", precision: 0) %></strong></div>
                </div>

                <div class="button-row">
                  <%= link_to "모의 결제 완료", preview_student_order_complete_path, class: "button button--primary button--small" %>
                </div>
              </article>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
