<aside class="admin-preview-nav">
  <div class="admin-preview-nav__brand">
    <p class="eyebrow">Preview student</p>
    <h2>월정액 멤버십</h2>
    <p>SpeakFlow를 강의 판매보다 훈련 구독 서비스에 가깝게 운영할 때의 구매 흐름을 보는 테스트 영역입니다.</p>
  </div>

  <nav class="admin-preview-nav__links" aria-label="학생 멤버십 메뉴">
    <%= link_to "멤버십 소개", preview_student_membership_path, class: "admin-preview-link #{current_page?(preview_student_membership_path) ? 'is-active' : ''}" %>
    <%= link_to "요금제 비교", preview_student_membership_plans_path, class: "admin-preview-link #{current_page?(preview_student_membership_plans_path) ? 'is-active' : ''}" %>
    <%= link_to "가입 결제", preview_student_membership_checkout_path, class: "admin-preview-link #{current_page?(preview_student_membership_checkout_path) ? 'is-active' : ''}" %>
    <%= link_to "내 멤버십", preview_student_membership_account_path, class: "admin-preview-link #{current_page?(preview_student_membership_account_path) ? 'is-active' : ''}" %>
  </nav>

  <div class="admin-preview-nav__meta">
    <div class="admin-preview-mini">
      <span>월 시작가</span>
      <strong><%= number_to_currency(@membership_plans.first[:price], unit: "₩", precision: 0) %></strong>
    </div>
    <div class="admin-preview-mini">
      <span>추천 플랜</span>
      <strong><%= @selected_plan[:name] %></strong>
    </div>
  </div>
</aside>
