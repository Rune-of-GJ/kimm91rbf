<% content_for :title, "SpeakFlow | Preview Coaching Requests" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/student/coaching/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">내 첨삭 현황 테스트 페이지</h1>
              <p class="section-copy">
                학생은 요청을 넣은 뒤 지금 누구 차례인지, 어떤 크레딧을 썼는지, 피드백이 도착했는지를 가장 궁금해합니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <article class="surface-card admin-preview-panel">
              <span class="pill pill--accent">요청 목록</span>
              <div class="commerce-list">
                <% @feedback_requests.each do |request| %>
                  <div class="commerce-line">
                    <div>
                      <strong><%= request[:title] %></strong>
                      <span><%= request[:submitted_on].strftime("%Y.%m.%d") %> · <%= request[:credit_source] %></span>
                    </div>
                    <strong><%= request[:status] %></strong>
                  </div>
                <% end %>
              </div>
            </article>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
