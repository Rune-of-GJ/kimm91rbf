<% content_for :title, "SpeakFlow | Preview Coaching Request" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/student/coaching/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">첨삭 요청 테스트 페이지</h1>
              <p class="section-copy">
                학생이 남은 Coach 포함 첨삭을 쓸지, 별도 구매권을 쓸지 고른 뒤 리허설 파일을 제출하는 흐름입니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <div class="detail-grid">
              <article class="surface-card admin-preview-panel">
                <span class="pill pill--accent">첨삭 요청 작성</span>
                <div class="admin-preview-form-grid">
                  <label class="field">
                    <span>요청 제목</span>
                    <input type="text" value="면접 자기소개 리허설" readonly>
                  </label>
                  <label class="field">
                    <span>사용 크레딧</span>
                    <select disabled>
                      <option>Coach 포함 1회 사용</option>
                      <option>별도 구매권 1회 사용</option>
                    </select>
                  </label>
                  <label class="field field--full">
                    <span>녹음 파일</span>
                    <input type="text" value="self-intro-rehearsal.m4a" readonly>
                  </label>
                  <label class="field field--full">
                    <span>첨삭 요청 메모</span>
                    <textarea readonly>첫 20초 도입이 너무 평평하게 들리는지, 면접 톤으로 자연스러운지 봐주세요.</textarea>
                  </label>
                </div>
                <div class="button-row">
                  <%= link_to "요청 완료 시안 보기", preview_student_coaching_request_complete_path, class: "button button--primary button--small" %>
                </div>
              </article>

              <article class="surface-card admin-preview-panel">
                <span class="pill">크레딧 안내</span>
                <div class="meta-list">
                  <div class="meta-item"><span>Coach 포함 남은 수량</span><strong><%= @active_membership[:remaining_credits] %>회</strong></div>
                  <div class="meta-item"><span>다음 갱신일</span><strong><%= @active_membership[:renews_on].strftime("%Y.%m.%d") %></strong></div>
                </div>
                <div class="admin-preview-note">
                  <strong>상품 병행 규칙</strong>
                  <p>포함 첨삭을 다 쓰면 별도 구매권을 먼저 제안하고, 그래도 없으면 Coach 업그레이드로 유도하는 흐름을 가정합니다.</p>
                </div>
              </article>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
