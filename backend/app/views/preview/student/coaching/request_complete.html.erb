<% content_for :title, "SpeakFlow | Preview Coaching Request Complete" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/student/coaching/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">첨삭 요청 완료 테스트 페이지</h1>
              <p class="section-copy">
                요청이 정상 접수됐다는 안심과, 다음 행동으로 무엇을 해야 하는지를 같이 보여주는 완료 화면입니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <div class="detail-grid">
              <article class="surface-card admin-preview-panel">
                <span class="pill pill--accent">요청 완료</span>
                <h3>첨삭 요청이 접수되었습니다.</h3>
                <p>강사가 순서대로 확인한 뒤 타임코드 피드백과 총평을 남기는 흐름을 가정합니다.</p>
                <div class="button-row">
                  <%= link_to "내 첨삭 현황 보기", preview_student_coaching_requests_path, class: "button button--primary" %>
                </div>
              </article>

              <article class="surface-card admin-preview-panel">
                <span class="pill">차감 내역</span>
                <div class="meta-list">
                  <div class="meta-item"><span>사용 크레딧</span><strong>Coach 포함 1회</strong></div>
                  <div class="meta-item"><span>남은 포함 첨삭</span><strong><%= @active_membership[:remaining_credits] - 1 %>회</strong></div>
                </div>
              </article>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
