<aside class="admin-preview-nav">
  <div class="admin-preview-nav__brand">
    <p class="eyebrow">Preview student</p>
    <h2>1:1 첨삭 흐름</h2>
    <p>월정액과 별도 첨삭권을 함께 운영할 때 학생이 보게 될 구매와 요청 흐름을 테스트하는 영역입니다.</p>
  </div>

  <nav class="admin-preview-nav__links" aria-label="학생 첨삭 메뉴">
    <%= link_to "첨삭 상품", preview_student_coaching_products_path, class: "admin-preview-link #{current_page?(preview_student_coaching_products_path) ? 'is-active' : ''}" %>
    <%= link_to "첨삭 요청", preview_student_coaching_request_path, class: "admin-preview-link #{current_page?(preview_student_coaching_request_path) ? 'is-active' : ''}" %>
    <%= link_to "내 첨삭 현황", preview_student_coaching_requests_path, class: "admin-preview-link #{current_page?(preview_student_coaching_requests_path) ? 'is-active' : ''}" %>
    <%= link_to "요청 완료", preview_student_coaching_request_complete_path, class: "admin-preview-link #{current_page?(preview_student_coaching_request_complete_path) ? 'is-active' : ''}" %>
  </nav>

  <div class="admin-preview-nav__meta">
    <div class="admin-preview-mini">
      <span>남은 포함 첨삭</span>
      <strong><%= @active_membership[:remaining_credits] %>회</strong>
    </div>
    <div class="admin-preview-mini">
      <span>Coach 혜택</span>
      <strong>월 <%= @active_membership[:included_credits] %>회</strong>
    </div>
  </div>
</aside>
