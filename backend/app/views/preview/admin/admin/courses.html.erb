<% content_for :title, "SpeakFlow | Preview Admin Courses" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "preview/admin/admin/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">강의 관리 테스트 페이지</h1>
              <p class="section-copy">
                관리자가 강의 상태를 확인하고 강사, 카테고리, 강의 수를 기준으로 관리하는 화면 구조 시안입니다.
              </p>
            </div>
          </section>

          <section class="page-section">
            <article class="surface-card admin-preview-panel">
              <div class="split-between">
                <div>
                  <span class="pill">Course table</span>
                  <h3 style="margin-top: 14px;">강의 목록</h3>
                </div>
                <div class="button-row">
                  <button type="button" class="button button--secondary button--small" disabled>공개 상태</button>
                  <button type="button" class="button button--ghost button--small" disabled>삭제</button>
                </div>
              </div>

              <div class="admin-preview-table">
                <div class="admin-preview-table__row admin-preview-table__row--head">
                  <span>강의명</span>
                  <span>카테고리</span>
                  <span>강사</span>
                  <span>강의 수</span>
                  <span>액션</span>
                </div>

                <% @preview_courses.each do |course| %>
                  <div class="admin-preview-table__row">
                    <span><strong><%= course.title %></strong></span>
                    <span><%= course.category.name %></span>
                    <span><%= course.instructor_name %></span>
                    <span><%= course.lectures.count %>개</span>
                    <span class="admin-preview-actions">
                      <button type="button" class="button button--secondary button--small" disabled>검토</button>
                      <button type="button" class="button button--ghost button--small" disabled>삭제</button>
                    </span>
                  </div>
                <% end %>
              </div>
            </article>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
