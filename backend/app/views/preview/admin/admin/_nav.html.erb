<aside class="admin-preview-nav">
  <div class="admin-preview-nav__brand">
    <p class="eyebrow">Preview admin</p>
    <h2>관리자 테스트</h2>
    <p>실제 반영 전용 시안 영역입니다.</p>
  </div>

  <nav class="admin-preview-nav__links" aria-label="관리자 미리보기 메뉴">
    <%= link_to "대시보드", preview_admin_dashboard_path, class: "admin-preview-link #{current_page?(preview_admin_dashboard_path) ? 'is-active' : ''}" %>
    <%= link_to "진입 방법", preview_admin_entry_path, class: "admin-preview-link #{current_page?(preview_admin_entry_path) ? 'is-active' : ''}" %>
    <%= link_to "관리자 계정 생성", preview_admin_account_path, class: "admin-preview-link #{current_page?(preview_admin_account_path) ? 'is-active' : ''}" %>
    <%= link_to "접근 제한", preview_admin_policy_path, class: "admin-preview-link #{current_page?(preview_admin_policy_path) ? 'is-active' : ''}" %>
    <%= link_to "사용자 관리", preview_admin_users_path, class: "admin-preview-link #{current_page?(preview_admin_users_path) ? 'is-active' : ''}" %>
    <%= link_to "강의 관리", preview_admin_courses_path, class: "admin-preview-link #{current_page?(preview_admin_courses_path) ? 'is-active' : ''}" %>
    <%= link_to "월정액 정산", preview_admin_settlement_membership_path, class: "admin-preview-link #{current_page?(preview_admin_settlement_membership_path) ? 'is-active' : ''}" %>
    <%= link_to "첨삭 정산", preview_admin_settlement_coaching_path, class: "admin-preview-link #{current_page?(preview_admin_settlement_coaching_path) ? 'is-active' : ''}" %>
    <%= link_to "강사별 정산", preview_admin_settlement_instructors_path, class: "admin-preview-link #{current_page?(preview_admin_settlement_instructors_path) ? 'is-active' : ''}" %>
    <%= link_to "강사 강의등록", preview_instructor_course_new_path, class: "admin-preview-link #{current_page?(preview_instructor_course_new_path) ? 'is-active' : ''}" %>
  </nav>

  <div class="admin-preview-nav__meta">
    <div class="admin-preview-mini">
      <span>전체 사용자</span>
      <strong><%= @preview_counts[:users] %></strong>
    </div>
    <div class="admin-preview-mini">
      <span>전체 강의</span>
      <strong><%= @preview_counts[:courses] %></strong>
    </div>
  </div>
</aside>
