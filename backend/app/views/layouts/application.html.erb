<!DOCTYPE html>
<html lang="ko">
  <head>
    <title><%= content_for(:title) || "SpeakFlow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="SpeakFlow">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <script src="https://js.tosspayments.com/v2/payment"></script>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app-shell" data-controller="shell" data-shell-logout-url-value="<%= api_v1_auth_logout_path %>">
      <%= render "layouts/site_header" %>
      <%= render "layouts/flash" %>
      <%= yield %>
      <%= render "layouts/site_footer" %>
      <% if current_user %>
        <%= render "layouts/user_panel" %>
      <% end %>
      <div class="app-overlay" data-shell-target="overlay" data-action="click->shell#closeAll"></div>
    </div>
  </body>
</html>
