<article class="surface-card admin-preview-panel <%= local_assigns[:form_article_class] %>">
  <span class="pill pill--accent"><%= submit_label %></span>

  <%= form_with model: [:instructor, course], class: "admin-preview-panel", multipart: true do |form| %>
    <div class="<%= local_assigns[:form_grid_class] || 'admin-preview-form-grid admin-preview-form-grid--wide' %>">
      <label class="field field--span-2">
        <span>강의 제목</span>
        <%= form.text_field :title, placeholder: "예: 프로페셔널 보이스 트레이닝" %>
      </label>

      <label class="field">
        <span>강사</span>
        <input type="text" value="<%= current_user.name %>" readonly>
      </label>

      <label class="field">
        <span>카테고리</span>
        <%= form.collection_select :category_id, categories, :id, :name, { prompt: "카테고리를 선택하세요" }, {} %>
      </label>

      <label class="field field--full" data-controller="file-preview">
        <span>썸네일 파일</span>
        <%= file_field_tag "course[thumbnail_file]", accept: "image/*", data: { action: "change->file-preview#preview", file_preview_target: "input" } %>
        <div class="thumbnail-upload-preview">
          <% if course.thumbnail_url.present? %>
            <img src="<%= course.thumbnail_url %>" data-file-preview-target="image" alt="<%= course.title.presence || '강의' %> 썸네일 미리보기">
            <div hidden class="thumbnail-upload-preview__empty" data-file-preview-target="empty">
              선택한 이미지가 여기에서 미리보기로 표시됩니다.
            </div>
          <% else %>
            <img hidden data-file-preview-target="image" alt="썸네일 미리보기">
            <div class="thumbnail-upload-preview__empty" data-file-preview-target="empty">
              선택한 이미지가 여기에서 미리보기로 표시됩니다.
            </div>
          <% end %>
        </div>
      </label>

      <label class="field field--full">
        <span>강의 소개</span>
        <%= form.text_area :description, placeholder: "강의 목표와 수강생이 얻게 될 변화를 적어주세요." %>
      </label>
    </div>

    <div class="button-row">
      <%= form.submit submit_label, class: "button button--primary button--small" %>
      <%= link_to "강의 목록으로", instructor_courses_path, class: "button button--secondary button--small" %>
    </div>
  <% end %>
</article>
