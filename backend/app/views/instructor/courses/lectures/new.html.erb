<% content_for :title, "SpeakFlow | 섹션 추가" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "instructor/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <p class="eyebrow">Instructor</p>
              <h1 class="section-title">섹션 추가</h1>
              <p class="section-copy"><%= @course.title %> 안에 새 섹션을 추가합니다.</p>
            </div>
          </section>

          <section class="page-section">
            <div class="detail-grid detail-grid--wide">
              <article class="surface-card admin-preview-panel">
                <span class="pill pill--accent">새 섹션</span>
                <%= render "form", submit_label: "섹션 추가" %>
              </article>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
