<% content_for :title, "SpeakFlow | 섹션 수정" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "instructor/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <p class="eyebrow">Instructor</p>
              <h1 class="section-title">섹션 수정</h1>
              <p class="section-copy"><%= @course.title %> 안의 섹션 제목과 유튜브 링크를 수정합니다.</p>
            </div>
          </section>

          <section class="page-section">
            <div class="detail-grid detail-grid--wide">
              <article class="surface-card admin-preview-panel">
                <span class="pill pill--accent">섹션 수정</span>
                <%= render "form", submit_label: "섹션 저장" %>
              </article>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
