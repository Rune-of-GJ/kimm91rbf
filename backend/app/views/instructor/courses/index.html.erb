<% content_for :title, "SpeakFlow | 강사 강의 관리" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "instructor/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <p class="eyebrow">Instructor</p>
              <h1 class="section-title">내 강의 관리</h1>
              <p class="section-copy">강의 목록은 가볍게 보고, 세부 관리와 섹션 추가는 강의 수정 안에서 이어서 진행할 수 있습니다.</p>
            </div>

            <div class="stats-grid">
              <article class="stat-card">
                <span class="stat-card__value"><%= @instructor_counts[:courses] %></span>
                <span class="stat-card__label">등록 강의</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__value"><%= @instructor_counts[:upcoming] %></span>
                <span class="stat-card__label">예정 강의</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__value"><%= @instructor_courses.sum { |course| course.lectures.size } %></span>
                <span class="stat-card__label">전체 강의편</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__value"><%= @instructor_courses.sum { |course| course.enrollments.size } %></span>
                <span class="stat-card__label">전체 수강생</span>
              </article>
            </div>
          </section>

          <section class="page-section">
            <div class="section-heading" style="margin-bottom: 26px;">
              <h2 class="section-title" style="font-size: 34px;">강의 목록</h2>
              <p class="section-copy">제목과 수강생 수만 빠르게 확인하고, 필요한 관리는 버튼으로 들어갑니다.</p>
            </div>

            <div class="course-grid">
              <% @instructor_courses.each do |course| %>
                <article class="surface-card admin-preview-panel course-card course-card--compact">
                  <h3><%= course.title %></h3>

                  <div class="meta-list course-card__meta course-card__meta--single">
                    <div class="meta-item">
                      <span>수강생</span>
                      <strong><%= course.enrollments.size %>명</strong>
                    </div>
                  </div>

                  <div class="button-row course-card__actions">
                    <%= link_to "세부 보기", edit_instructor_course_path(course), class: "button button--secondary button--small" %>
                    <%= link_to "강의 수정", edit_instructor_course_path(course), class: "button button--secondary button--small" %>
                    <%= button_to "강의 삭제", instructor_course_path(course), method: :delete, class: "button button--secondary button--small", form: { data: { turbo_confirm: "정말 이 강의를 삭제할까요?" } } %>
                  </div>
                </article>
              <% end %>

              <%= link_to new_instructor_course_path, class: "surface-card course-create-card course-create-card--compact" do %>
                <span class="course-create-card__plus">+</span>
                <strong>새 강의 만들기</strong>
              <% end %>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
