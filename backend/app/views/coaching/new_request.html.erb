<% content_for :title, "SpeakFlow | 첨삭 요청" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "coaching/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">첨삭 요청 작성</h1>
              <p class="section-copy">보내고 싶은 음성과 메모, 대상 강의를 함께 남기면 해당 강사가 바로 확인할 수 있는 요청으로 저장됩니다.</p>
            </div>
          </section>

          <section class="page-section">
            <% if @coaching_balance == 0 %>
              <article class="surface-card admin-preview-note" style="margin-bottom: 24px;">
                <strong>첨삭 크레딧이 없습니다.</strong>
                <p style="margin-top: 8px;">요청을 보내려면 크레딧이 필요합니다. 멤버십 플랜을 통해 매월 크레딧을 받거나, 첨삭 크레딧을 별도로 구매할 수 있습니다.</p>
                <div class="button-row" style="margin-top: 14px;">
                  <%= link_to "크레딧 구매하기", coaching_products_path, class: "button button--primary button--small" %>
                  <%= link_to "멤버십 보기", membership_plans_path, class: "button button--secondary button--small" %>
                </div>
              </article>
            <% end %>

            <article class="surface-card admin-preview-panel">
              <div class="meta-list" style="margin-bottom: 24px;">
                <div class="meta-item"><span>현재 첨삭 잔액</span><strong><%= @coaching_balance %>회</strong></div>
                <div class="meta-item"><span>사용 방식</span><strong>요청 1건당 1회 차감</strong></div>
              </div>

              <% if @feedback_request.errors.any? %>
                <article class="surface-card admin-preview-note">
                  <strong>요청을 저장하지 못했습니다.</strong>
                  <p><%= @feedback_request.errors.full_messages.join(", ") %></p>
                </article>
              <% end %>

              <%= form_with model: @feedback_request,
                url: coaching_request_path,
                class: "auth-form coaching-request-form",
                multipart: true,
                data: { controller: "coaching-request" } do |form| %>
                <div class="coaching-request-grid">
                  <div class="field field--full">
                    <%= form.label :title, "요청 제목" %>
                    <%= form.text_field :title, required: true, placeholder: "예: 면접 자기소개 리허설" %>
                  </div>

                  <div class="field">
                    <%= form.label :course_id, "대상 강의" %>
                    <%= form.select :course_id,
                      options_for_select([["강의를 선택하세요", ""]] + @available_courses.map { |course| [course.title, course.id] }, @feedback_request.course_id),
                      {},
                      { required: true, data: { coaching_request_target: "courseSelect", action: "change->coaching-request#filterLectures" } } %>
                  </div>

                  <div class="field">
                    <%= form.label :lecture_id, "대상 강의편" %>
                    <select
                      name="feedback_request[lecture_id]"
                      id="feedback_request_lecture_id"
                      required
                      data-coaching-request-target="lectureSelect">
                      <option value="">강의편을 선택하세요</option>
                      <% @available_lectures.each do |lecture| %>
                        <option
                          value="<%= lecture.id %>"
                          data-course-id="<%= lecture.course_id %>"
                          <%= "selected" if @feedback_request.lecture_id == lecture.id %>>
                          <%= lecture.course.title %> · <%= lecture.title %>
                        </option>
                      <% end %>
                    </select>
                  </div>

                  <div class="field">
                    <%= form.label :audio_file, "음성 파일 업로드" %>
                    <%= form.file_field :audio_file, accept: "audio/*", class: "file-upload-input" %>
                  </div>

                  <div class="field">
                    <%= form.label :audio_reference, "음성 링크 또는 메모용 파일명" %>
                    <%= form.text_field :audio_reference, placeholder: "예: intro-rehearsal-01.m4a" %>
                  </div>
                </div>

                <div class="field field--full">
                  <%= form.label :note, "메모" %>
                  <%= form.text_area :note, rows: 6, placeholder: "답을 봐줬으면 하는 구간이나 고민을 적어주세요." %>
                </div>

                <div class="button-row coaching-request-actions">
                  <%= form.submit "첨삭 요청 보내기", class: "button button--primary", disabled: @coaching_balance == 0 %>
                  <%= link_to "첨삭 상품 보기", coaching_products_path, class: "button button--secondary" %>
                </div>
              <% end %>
            </article>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
