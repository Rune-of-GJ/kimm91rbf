<% content_for :title, "SpeakFlow | 결제 실패" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "coaching/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <h1 class="section-title">결제에 실패했습니다</h1>
              <p class="section-copy"><%= @message %></p>
            </div>
          </section>

          <section class="page-section">
            <div class="button-row">
              <%= link_to "첨삭 상품으로 돌아가기", coaching_products_path, class: "button button--primary" %>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
