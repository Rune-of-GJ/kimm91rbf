<% content_for :title, "SpeakFlow | Admin Instructor Settlement Summary" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "admin/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <p class="eyebrow">Admin settlement</p>
              <h1 class="section-title">강사별 정산 요약</h1>
              <p class="section-copy">월정액 정산과 첨삭 정산을 합산해 강사별 예상 지급액을 확인합니다.</p>
            </div>
          </section>

          <section class="page-section">
            <div class="admin-preview-table admin-preview-table--wide">
              <div class="admin-preview-table__row admin-preview-table__row--head">
                <span>강사</span>
                <span>월정액 정산</span>
                <span>첨삭 정산</span>
                <span>이월액</span>
                <span>최종 지급액</span>
                <span>상태</span>
              </div>
              <% @settlement_rows.each do |row| %>
                <div class="admin-preview-table__row admin-preview-table__row--wide">
                  <span><strong><%= row[:instructor] %></strong></span>
                  <span><%= number_to_currency(row[:membership_payout], unit: "₩", precision: 0) %></span>
                  <span><%= number_to_currency(row[:coaching_payout], unit: "₩", precision: 0) %></span>
                  <span><%= number_to_currency(row[:hold_amount], unit: "₩", precision: 0) %></span>
                  <span><strong><%= number_to_currency(row[:final_payout], unit: "₩", precision: 0) %></strong></span>
                  <span><%= row[:status] %></span>
                </div>
              <% end %>
            </div>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
