<% content_for :title, "SpeakFlow | Admin Users" %>

<main class="page">
  <section class="surface surface--preview-admin">
    <div class="container surface__inner">
      <div class="admin-preview-shell">
        <%= render "admin/nav" %>

        <section class="admin-preview-main">
          <section class="page-section">
            <div class="section-heading">
              <p class="eyebrow">Admin</p>
              <h1 class="section-title">사용자 관리</h1>
              <p class="section-copy">전체 계정을 기준으로 역할을 확인하고, 권한 변경과 계정 삭제를 수행할 수 있습니다.</p>
            </div>

            <div class="stats-grid">
              <article class="stat-card">
                <span class="stat-card__value"><%= @admin_counts[:users] %></span>
                <span class="stat-card__label">전체 사용자</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__value"><%= @admin_counts[:instructors] %></span>
                <span class="stat-card__label">강사</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__value"><%= @admin_counts[:students] %></span>
                <span class="stat-card__label">수강생</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__value"><%= @admin_counts[:admins] %></span>
                <span class="stat-card__label">관리자</span>
              </article>
            </div>
          </section>

          <section class="page-section">
            <article class="surface-card admin-preview-panel">
              <div class="split-between">
                <div>
                  <span class="pill pill--accent">Search & filter</span>
                  <h3 style="margin-top: 14px;">역할 필터와 검색</h3>
                </div>
              </div>

              <form action="<%= admin_users_path %>" method="get" class="admin-preview-search">
                <label class="field">
                  <span>이름 또는 이메일 검색</span>
                  <input type="text" name="q" value="<%= @query %>" placeholder="예: 김강사, student@speakflow.kr">
                </label>
                <div class="button-row">
                  <button type="submit" class="button button--primary button--small">검색</button>
                  <%= link_to "초기화", admin_users_path, class: "button button--secondary button--small" %>
                </div>
              </form>

              <div class="chip-row">
                <% [["all", "전체"], ["instructor", "강사"], ["student", "수강생"], ["admin", "관리자"]].each do |value, label| %>
                  <% count = value == "all" ? @admin_counts[:users] : @admin_counts[value.pluralize.to_sym] %>
                  <%= link_to "#{label} #{count}", admin_users_path(role: value, q: @query.presence), class: "category-filter #{@role_filter == value ? 'is-active' : ''}" %>
                <% end %>
              </div>
            </article>
          </section>

          <section class="page-section">
            <article class="surface-card admin-preview-panel">
              <div class="split-between">
                <div>
                  <span class="pill pill--accent">User table</span>
                  <h3 style="margin-top: 14px;">사용자 전체 목록</h3>
                </div>
              </div>

              <div class="admin-preview-table admin-preview-table--users">
                <div class="admin-preview-table__row admin-preview-table__row--head">
                  <span>이름</span>
                  <span>이메일</span>
                  <span>역할 변경</span>
                  <span>활동 정보</span>
                  <span>가입일</span>
                  <span>삭제</span>
                </div>

                <% @users.each do |user| %>
                  <div class="admin-preview-table__row">
                    <span><strong><%= user.name %></strong></span>
                    <span><%= user.email %></span>
                    <span>
                      <%= form_with model: user, url: admin_user_path(user, role: @role_filter, q: @query.presence), method: :patch, local: true, class: "admin-inline-form" do |form| %>
                        <div class="admin-inline-form__row">
                          <%= form.select :role, User.roles.keys.map { |role| [role, role] }, {}, class: "admin-inline-form__select" %>
                          <%= form.submit "저장", class: "button button--secondary button--small" %>
                        </div>
                      <% end %>
                    </span>
                    <span>
                      <% if user.instructor? %>
                        담당 강의 <%= user.instructed_courses.size %>개
                      <% elsif user.student? %>
                        수강 강의 <%= user.enrollments.size %>개
                      <% else %>
                        시스템 관리
                      <% end %>
                    </span>
                    <span><%= user.created_at.strftime("%Y.%m.%d") %></span>
                    <span class="admin-preview-actions">
                      <%= button_to "삭제", admin_user_path(user, role: @role_filter, q: @query.presence), method: :delete, class: "button button--ghost button--small", form: { data: { turbo_confirm: "#{user.name} 계정을 삭제할까요?" } } %>
                    </span>
                  </div>
                <% end %>
              </div>
            </article>
          </section>
        </section>
      </div>
    </div>
  </section>
</main>
